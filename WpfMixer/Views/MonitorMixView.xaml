<UserControl x:Class="WpfMixer.Views.MonitorMixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeep}">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF101010" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10,8" CornerRadius="4">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock Text="MONITOR MIX" Foreground="White" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" FontSize="14" Margin="0,0,12,0"/>
                    <Button Content="BUS 1" Style="{StaticResource PtButton}" Command="{Binding SelectBusCommand}" CommandParameter="1" Margin="0,0,4,0"/>
                    <Button Content="BUS 2" Style="{StaticResource PtButton}" Command="{Binding SelectBusCommand}" CommandParameter="2" Margin="0,0,4,0"/>
                    <Button Content="BUS 3" Style="{StaticResource PtButton}" Command="{Binding SelectBusCommand}" CommandParameter="3" Margin="0,0,4,0"/>
                    <Button Content="BUS 4" Style="{StaticResource PtButton}" Command="{Binding SelectBusCommand}" CommandParameter="4" Margin="0,0,4,0"/>
                    <Button Content="BUS 5" Style="{StaticResource PtButton}" Command="{Binding SelectBusCommand}" CommandParameter="5" Margin="0,0,4,0"/>
                    <Button Content="BUS 6" Style="{StaticResource PtButton}" Command="{Binding SelectBusCommand}" CommandParameter="6" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding SelectedBusIndex, StringFormat=Selected: Bus {0}}" Foreground="{StaticResource Accent}" VerticalAlignment="Center" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
                <CheckBox DockPanel.Dock="Right" Content="MY MIX"
                          IsChecked="{Binding MyMixMode, Mode=TwoWay}"
                          Foreground="{StaticResource TextPrimary}" FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,10,0,0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal">
                <ItemsControl ItemsSource="{Binding ChannelSends}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource BgStrip}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="3,0" Padding="6" CornerRadius="4" Width="88">
                                <StackPanel>
                                    <TextBlock Text="{Binding ChannelName}" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontWeight="Bold"/>
                                    <Slider Style="{StaticResource VerticalFader}" Height="260"
                                            Value="{Binding SendLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                                    <ToggleButton IsChecked="{Binding SendOn, Mode=TwoWay}" Content="ON" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Background="#FF111111" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="8,0,0,0" Padding="8" Width="100">
                    <StackPanel>
                        <TextBlock Text="MASTER" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontWeight="Bold"/>
                        <Slider Style="{StaticResource VerticalFader}" Height="260" Value="{Binding BusMasterLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/>
                        <ToggleButton IsChecked="{Binding BusMasterMute, Mode=TwoWay}" Content="MUTE" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
