<UserControl x:Class="WpfMixer.Views.UsbRoutingGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeep}">

    <UserControl.Resources>
        <Style x:Key="GridHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
        <Style x:Key="SlotLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Width" Value="54" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="4,0" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12">

            <!-- Mode selector -->
            <Border Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="2" Padding="12,8" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="USB MODE:"
                               Foreground="{StaticResource TextSecondary}"
                               FontFamily="{StaticResource MonoFont}" FontSize="10"
                               VerticalAlignment="Center" Margin="0,0,12,0" />
                    <RadioButton Content="MULTITRACK"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumToBool}, ConverterParameter=Multitrack}"
                                 Foreground="White" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                 Margin="0,0,20,0" />
                    <RadioButton Content="STEREO"
                                 IsChecked="{Binding Mode, Converter={StaticResource EnumToBool}, ConverterParameter=Stereo}"
                                 Foreground="White" FontFamily="{StaticResource MonoFont}" FontSize="10" />
                </StackPanel>
            </Border>

            <!-- Two-column layout: sends left, returns right -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ─── USB SENDS ─── -->
                <StackPanel Grid.Column="0">
                    <Border Background="{StaticResource BgPanel}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="2,2,0,0" Padding="8,5">
                        <TextBlock Text="USB SENDS  (Channel -> USB Slot)"
                                   Foreground="{StaticResource Accent}"
                                   FontFamily="{StaticResource MonoFont}" FontSize="10"
                                   FontWeight="Bold" />
                    </Border>
                    <ItemsControl ItemsSource="{Binding SendSlots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgStrip}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1,0,1,1" Padding="6,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="96" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Label, StringFormat=USB {0}}"
                                                   Style="{StaticResource SlotLabel}" />
                                        <TextBlock Grid.Column="1" Text="&lt;=" Style="{StaticResource GridHeader}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="2" Width="88" Height="22"
                                                  SelectedItem="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding Options}"
                                                  FontFamily="{StaticResource MonoFont}" FontSize="9"
                                                  Background="{StaticResource BgControl}"
                                                  Foreground="{StaticResource TextSecondary}"
                                                  BorderBrush="{StaticResource BorderBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- ─── USB RETURNS ─── -->
                <StackPanel Grid.Column="2">
                    <Border Background="{StaticResource BgPanel}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="2,2,0,0" Padding="8,5">
                        <TextBlock Text="USB RETURNS  (USB Slot -> Channel)"
                                   Foreground="#CE93D8"
                                   FontFamily="{StaticResource MonoFont}" FontSize="10"
                                   FontWeight="Bold" />
                    </Border>
                    <ItemsControl ItemsSource="{Binding ReturnSlots}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgStrip}"
                                        BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="1,0,1,1" Padding="6,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="96" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Label, StringFormat=USB {0}}"
                                                   Style="{StaticResource SlotLabel}" Foreground="#CE93D8" />
                                        <TextBlock Grid.Column="1" Text="=&gt;"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontFamily="{StaticResource MonoFont}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center" />
                                        <ComboBox Grid.Column="2" Width="88" Height="22"
                                                  SelectedItem="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding Options}"
                                                  FontFamily="{StaticResource MonoFont}" FontSize="9"
                                                  Background="{StaticResource BgControl}"
                                                  Foreground="{StaticResource TextSecondary}"
                                                  BorderBrush="{StaticResource BorderBrush}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
