<UserControl x:Class="WpfMixer.Views.AutomationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDeep}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,8">
            <TextBlock DockPanel.Dock="Left" Text="AUTOMATION TIMELINE" FontFamily="{StaticResource MonoFont}" FontSize="13" FontWeight="Bold"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Add Track" Style="{StaticResource PtButton}" Command="{Binding AddTrackCommand}" Margin="0,0,6,0"/>
                <Button Content="Remove Track" Style="{StaticResource PtButton}" Command="{Binding RemoveTrackCommand}"/>
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
                <StackPanel>
                    <TextBlock Text="TIMELINES" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,0,0,6"/>
                    <ListBox ItemsSource="{Binding Timelines}" SelectedItem="{Binding SelectedTimeline}" DisplayMemberPath="Name" Height="130"/>

                    <TextBlock Text="TRACKS" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,10,0,6"/>
                    <ListBox ItemsSource="{Binding SelectedTimeline.Tracks}" SelectedItem="{Binding SelectedTrack}" DisplayMemberPath="TargetPath"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{DynamicResource BgStrip}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="6" Background="{DynamicResource BgControl}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Path" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Width="250" Text="{Binding SelectedTrack.TargetPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,14,0"/>
                            <TextBlock Text="Snap" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Width="70" Text="{Binding SnapDivisionSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0"/>
                            <Button Content="Snap All" Style="{StaticResource PtButton}" Command="{Binding SnapAllToGridCommand}"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Padding="6" Background="{DynamicResource BgControl}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Time" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Width="80" Text="{Binding NewKeyframeTimeSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                            <TextBlock Text="Value" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Width="80" Text="{Binding NewKeyframeValue, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,10,0"/>
                            <Button Content="Add Keyframe" Style="{StaticResource PtButton}" Command="{Binding AddKeyframeCommand}" Margin="0,0,6,0"/>
                            <Button Content="Remove Selected" Style="{StaticResource PtButton}" Command="{Binding RemoveSelectedKeyframeCommand}"/>
                        </StackPanel>
                    </Border>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding SelectedTrack.Keyframes}"
                              SelectedItem="{Binding SelectedKeyframe}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              Background="{DynamicResource BgPanel}"
                              Foreground="{DynamicResource TextPrimary}"
                              BorderBrush="{DynamicResource BorderBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time (s)" Binding="{Binding TimeSeconds, Mode=TwoWay, StringFormat=F3}" Width="120"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay, StringFormat=F3}" Width="120"/>
                            <DataGridComboBoxColumn Header="Interpolation"
                                                    SelectedItemBinding="{Binding Interpolation, Mode=TwoWay}"
                                                    ItemsSource="{Binding DataContext.Interpolations, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Play" Style="{StaticResource PtButton}" Command="{Binding PlayCommand}" Margin="0,0,6,0"/>
            <Button Content="Stop" Style="{StaticResource PtButton}" Command="{Binding StopCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
