<UserControl x:Class="WpfMixer.Views.RemoteControlView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WpfMixer.Converters"
             xmlns:vm="clr-namespace:WpfMixer.ViewModels"
             Background="{StaticResource BgDeep}">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToHighlightConverter x:Key="Highlight"/>

        <!-- Musician list item style -->
        <Style x:Key="MusicianItemStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" MinWidth="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ──────────────────────────────────────────────────────────── -->
        <!-- LEFT PANEL: Server controls + Musician list                  -->
        <!-- ──────────────────────────────────────────────────────────── -->
        <Border Grid.Column="0" Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12">

                <!-- Server status header -->
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="REMOTE CONTROL" FontSize="11" FontWeight="Bold"
                               FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource Accent}" Margin="0,0,0,8"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                                 VerticalAlignment="Center" Margin="0,0,4,0"
                                 ToolTip="Server port (default 8080)"/>
                        <Button Grid.Column="1" Width="80"
                                Command="{Binding ToggleServerCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PtButton}">
                                    <Setter Property="Content" Value="START"/>
                                    <Setter Property="Background" Value="#FF1A2A1A"/>
                                    <Setter Property="BorderBrush" Value="#FF1DB954"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Content" Value="STOP"/>
                                            <Setter Property="Background" Value="#FF2A1A1A"/>
                                            <Setter Property="BorderBrush" Value="#FFE53935"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>

                    <!-- Status row -->
                    <DockPanel Margin="0,0,0,4">
                        <Ellipse DockPanel.Dock="Left" Width="8" Height="8"
                                 VerticalAlignment="Center" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF444444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Fill" Value="#FF1DB954"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock Text="{Binding StatusText}"
                                   Foreground="{StaticResource TextSecondary}" FontSize="11"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </DockPanel>

                    <!-- Connected clients badge -->
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                               Visibility="{Binding IsRunning, Converter={StaticResource BoolVis}}">
                        <Run Text="{Binding ConnectedClients, Mode=OneWay}"/>
                        <Run Text="client(s) connected"/>
                    </TextBlock>
                </StackPanel>

                <!-- Divider -->
                <Separator DockPanel.Dock="Top" Margin="0,0,0,10"
                           Background="{StaticResource BorderBrush}"/>

                <!-- Musician list header -->
                <TextBlock DockPanel.Dock="Top"
                           Text="MUSICIANS" FontSize="10" FontWeight="Bold"
                           FontFamily="{StaticResource MonoFont}"
                           Foreground="{StaticResource TextSecondary}" Margin="0,0,0,6"/>

                <!-- Musician list -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Musicians}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:MusicianMixViewModel}">
                                <Border Padding="8,6">
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.SelectMusicianCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource MusicianItemStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                    <Setter Property="BorderBrush" Value="#FF1DB954"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Color dot -->
                                        <Ellipse Grid.Column="0" Width="10" Height="10"
                                                 VerticalAlignment="Center" Margin="0,0,8,0">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{Binding Color}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Name + bus -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{StaticResource TextPrimary}"
                                                       FontSize="12" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontFamily="{StaticResource MonoFont}">
                                                <Run Text="Bus"/>
                                                <Run Text="{Binding BusIndex, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <!-- Online indicator -->
                                        <Border Grid.Column="2"
                                                Background="#FF1DB954" CornerRadius="3" Padding="4,2"
                                                Visibility="{Binding IsOnline, Converter={StaticResource BoolVis}}">
                                            <TextBlock Text="LIVE" FontSize="8" FontWeight="Bold"
                                                       Foreground="Black" FontFamily="{StaticResource MonoFont}"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- ──────────────────────────────────────────────────────────── -->
        <!-- RIGHT PANEL: QR code + URL + Log                             -->
        <!-- ──────────────────────────────────────────────────────────── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="140"/>
            </Grid.RowDefinitions>

            <!-- QR + URL panel -->
            <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
                    Padding="20,16">
                <Grid>

                <!-- No musician selected placeholder -->
                <TextBlock Text="Select a musician to see their QR code."
                           Foreground="{StaticResource TextSecondary}" FontSize="13"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMusician}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Musician QR details -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedMusician}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- QR code image -->
                    <Border Grid.Column="0" Background="White" Padding="6" Margin="0,0,20,0"
                            VerticalAlignment="Top">
                        <Image Source="{Binding QrCode}" Width="180" Height="180"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"
                               Stretch="Uniform"/>
                    </Border>

                    <!-- Details -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">

                        <!-- Musician name header -->
                        <TextBlock Text="{Binding SelectedMusician.Name}"
                                   FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource Accent}"/>

                        <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11">
                            <Run Text="Bus "/>
                            <Run Text="{Binding SelectedMusician.BusIndex, Mode=OneWay}"
                                 Foreground="{StaticResource TextPrimary}" FontWeight="SemiBold"/>
                            <Run Text=" · "/>
                            <Run Text="{Binding SelectedMusician.Channels.Count, Mode=OneWay}"/>
                            <Run Text=" channels"/>
                        </TextBlock>

                        <!-- URL box -->
                        <Border Background="{StaticResource BgDeep}"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                CornerRadius="4" Padding="8,6">
                            <TextBlock Text="{Binding QrUrl}"
                                       Foreground="{StaticResource Accent}"
                                       FontFamily="{StaticResource MonoFont}"
                                       FontSize="11" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Buttons row -->
                        <StackPanel Orientation="Horizontal">
                            <Button Content="Copy Link"
                                    Style="{StaticResource PtButton}"
                                    Command="{Binding CopyLinkCommand}"/>
                            <Button Content="New Token"
                                    Style="{StaticResource PtButton}"
                                    Command="{Binding RegenerateTokenCommand}"
                                    ToolTip="Invalidates the current QR code and generates a new one"/>
                        </StackPanel>

                        <!-- Server start hint when stopped -->
                        <Border Background="#FF1A1207" BorderBrush="#FFFF8F00"
                                BorderThickness="1" CornerRadius="4" Padding="8,5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="⚠  Start the server to make QR codes active."
                                       Foreground="#FFFF8F00" FontSize="11"/>
                        </Border>

                        <!-- Channel list -->
                        <ItemsControl ItemsSource="{Binding SelectedMusician.Channels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,4,4" Padding="6,3"
                                            CornerRadius="3"
                                            BorderThickness="1">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="{Binding Color}"/>
                                        </Border.BorderBrush>
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   FontSize="10" FontFamily="{StaticResource MonoFont}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </Grid>

                </Grid><!-- /wrapper Grid inside Border -->
            </Border>

            <!-- Instructions panel -->
            <Border Grid.Row="1" Background="{StaticResource BgStrip}"
                    Padding="20,14">
                <StackPanel>
                    <TextBlock Text="HOW TO USE" FontSize="10" FontWeight="Bold"
                               FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource TextSecondary}"/>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="12"
                               TextWrapping="Wrap" LineHeight="20">
                        1. Press START to launch the local web server.<LineBreak/>
                        2. Select a musician from the list on the left.<LineBreak/>
                        3. Show them their QR code (fullscreen it or copy the link).<LineBreak/>
                        4. They scan it with their phone and control their own monitor mix.<LineBreak/>
                        5. Changes are instant via WebSocket ↔ OSC bridge.
                    </TextBlock>
                    <Separator Margin="0,6" Background="{StaticResource BorderBrush}"/>
                    <TextBlock Foreground="{StaticResource TextSecondary}" FontSize="11"
                               TextWrapping="Wrap">
                        <Run Text="Make sure your laptop and the musicians' phones are on the same Wi-Fi network.  The mixer must be connected first." Foreground="#FF666666"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Log panel -->
            <Border Grid.Row="2" Background="#FF0A0A0A"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                    Padding="10,6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="LOG" FontSize="9" FontWeight="Bold"
                               FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto"
                                  x:Name="LogScroller">
                        <TextBlock Text="{Binding LogText}"
                                   Foreground="#FF888888"
                                   FontFamily="{StaticResource MonoFont}"
                                   FontSize="10" TextWrapping="NoWrap"/>
                    </ScrollViewer>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</UserControl>
