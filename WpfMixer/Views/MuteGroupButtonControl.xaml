<UserControl x:Class="WpfMixer.Views.MuteGroupButtonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WpfMixer.Converters">

    <UserControl.Resources>
        <conv:BoolToHighlightConverter x:Key="Highlight"/>
    </UserControl.Resources>

    <Border CornerRadius="6" Padding="6,4"
            BorderThickness="2"
            BorderBrush="{Binding IsKeyHighlighted, Converter={StaticResource Highlight}}"
            MinWidth="100">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="#0f3460"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                        <Setter Property="Background" Value="#e94560"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel>
            <!-- Group name (editable) -->
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Background="Transparent" Foreground="White"
                     BorderThickness="0" FontWeight="Bold" FontSize="13"
                     TextAlignment="Center"/>

            <!-- Key badge + activate button -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                <Border Background="#1a1a2e" CornerRadius="4" Padding="4,2"
                        Cursor="Hand" Margin="0,0,4,0"
                        MouseLeftButtonUp="KeyBadge_Click">
                    <TextBlock FontSize="11" Foreground="#8af">
                        <Run Text="{Binding AssignedKey, FallbackValue='[key]'}"/>
                    </TextBlock>
                </Border>

                <Button Content="Fire" Foreground="White" FontSize="11"
                        Background="#533" BorderThickness="0" Cursor="Hand"
                        Padding="6,2" Click="FireGroup_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- Momentary + Edit + Remove -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                        Margin="0,4,0,0">
                <CheckBox Content="Mom." Foreground="#999" FontSize="10"
                          IsChecked="{Binding IsMomentaryMute}" Margin="0,0,6,0"/>
                <Button Content="Edit" FontSize="10" Background="#224"
                        Foreground="#aaf" BorderThickness="0" Cursor="Hand"
                        Padding="4,1" Margin="0,0,4,0" Click="EditGroup_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="3"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="✕" FontSize="10" Background="Transparent"
                        Foreground="#555" BorderThickness="0" Cursor="Hand"
                        Click="RemoveGroup_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
