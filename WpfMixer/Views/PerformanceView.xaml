<UserControl x:Class="WpfMixer.Views.PerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WpfMixer.ViewModels"
             Background="#FF030303"
             IsManipulationEnabled="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FF050505" BorderBrush="#FF1DB954" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="PERFORMANCE MODE" Foreground="#FF5DFF9A" FontSize="20" FontWeight="Bold" FontFamily="{StaticResource MonoFont}" Margin="0,0,14,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ActiveRoleLabel}" Foreground="#FF82D6FF" FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="SINGER/ENGINEER" MinHeight="48" MinWidth="150" Margin="0,0,8,0" Style="{StaticResource PtButton}" Command="{Binding ToggleViewModeCommand}"/>
                    <Button Content="LOCK" MinHeight="48" MinWidth="100" Margin="0,0,8,0" Style="{StaticResource PtButton}" Command="{Binding ToggleLockCommand}"/>
                    <TextBox Width="80" Text="{Binding LockPinInput, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,6,0" VerticalContentAlignment="Center" FontSize="18" MaxLength="8"/>
                    <Button Content="UNLOCK" MinHeight="48" MinWidth="100" Style="{StaticResource PtButton}" Command="{Binding TryUnlockCommand}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <CheckBox Content="Keep Selected Vocal Live" IsChecked="{Binding KeepSelectedVocalLive, Mode=TwoWay}" Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="PANIC MUTE"
                            MinHeight="52"
                            MinWidth="220"
                            FontSize="24"
                            FontWeight="Bold"
                            Foreground="White"
                            Background="{Binding PanicBrush}"
                            BorderBrush="#FFFF4A4A"
                            BorderThickness="2"
                            Command="{Binding TogglePanicMuteCommand}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="118"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#FF090909" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="4" Padding="8">
                <Grid IsEnabled="{Binding AreControlsEnabled}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Zoom" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <Slider Minimum="0.8" Maximum="2.6" Width="180" Value="{Binding ZoomScale, Mode=TwoWay}"/>
                        <TextBlock Text="{Binding ZoomScale, StringFormat={}{0:F2}x}" Foreground="#FF8CFFA8" FontFamily="{StaticResource MonoFont}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock Text="  •  Double-tap: reset fader  •  Long-press: rename" Foreground="#FFB8B8B8" Margin="14,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1"
                                  x:Name="MixerScroll"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  PanningMode="HorizontalOnly"
                                  IsManipulationEnabled="True"
                                  ManipulationDelta="MixerScroll_ManipulationDelta">
                        <ItemsControl ItemsSource="{Binding VisibleChannels}">
                            <ItemsControl.LayoutTransform>
                                <ScaleTransform ScaleY="{Binding ZoomScale}"/>
                            </ItemsControl.LayoutTransform>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:PerformanceChannelViewModel}">
                                    <Border Width="108" Margin="4,0" Padding="6" BorderThickness="2" CornerRadius="6"
                                            PreviewMouseLeftButtonDown="ChannelStrip_PreviewMouseLeftButtonDown"
                                            PreviewMouseLeftButtonUp="ChannelStrip_PreviewMouseLeftButtonUp"
                                            MouseLeave="ChannelStrip_MouseLeave">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#FF2B2B2B"/>
                                                <Setter Property="Background" Value="#FF121212"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsZoomed}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#FF5DFF9A"/>
                                                        <Setter Property="Background" Value="#FF1A261F"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <StackPanel>
                                            <Border Height="8" CornerRadius="2" Background="{Binding Color}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="White" TextAlignment="Center" TextWrapping="Wrap"/>

                                            <Grid Margin="0,8,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="24"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <ProgressBar Grid.Column="0" Height="220" Width="12" Maximum="1" Value="{Binding MeterLevel}" Foreground="#FF39FF14" Background="#FF202020" Margin="0,0,8,0"/>
                                                <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding FaderLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource VerticalFader}" Height="220"/>
                                            </Grid>

                                            <Slider Minimum="0" Maximum="1" Value="{Binding Pan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <ToggleButton Grid.Column="0" MinHeight="48" Margin="0,0,4,0" Content="MUTE" IsChecked="{Binding IsMuted, Mode=TwoWay}"/>
                                                <ToggleButton Grid.Column="1" MinHeight="48" Margin="4,0,0,0" Content="SOLO" IsChecked="{Binding IsSolo, Mode=TwoWay}"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#FF101010" BorderBrush="#FF3A3A3A" BorderThickness="1" Padding="8" Margin="0,8,0,0" CornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Singer Monitor Bus" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Slider Width="180" Minimum="0" Maximum="1" Value="{Binding SingerMonitorLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <ToggleButton Content="MON MUTE" MinHeight="48" MinWidth="110" Margin="8,0,0,0" IsChecked="{Binding SingerMonitorMute, Mode=TwoWay}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#FF0E0E0E" BorderBrush="#FF4A4A4A" BorderThickness="1" CornerRadius="4" Padding="6" Margin="8,0,0,0">
                <StackPanel DataContext="{Binding MainLrChannel}" IsEnabled="{Binding DataContext.AreControlsEnabled, RelativeSource={RelativeSource AncestorType=UserControl}}">
                    <TextBlock Text="MAIN LR" Foreground="#FF5DFF9A" FontWeight="Bold" FontFamily="{StaticResource MonoFont}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <ProgressBar Height="220" Maximum="1" Value="{Binding MeterLevel}" Foreground="#FFFFFF00" Background="#FF202020" Margin="0,0,0,8"/>
                    <Slider Style="{StaticResource VerticalFader}" Height="280" Minimum="0" Maximum="1" Value="{Binding FaderLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <ToggleButton MinHeight="48" Content="MUTE" IsChecked="{Binding IsMuted, Mode=TwoWay}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Grid Background="#A0000000" Visibility="Collapsed">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLocked}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="LOCKED" Foreground="#FFFF5A5A" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Controls disabled. PANIC MUTE remains active." Foreground="White" FontSize="18" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
