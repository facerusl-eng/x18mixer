<UserControl x:Class="WpfMixer.Views.AutomationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDeep}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="AUTOMATION TIMELINE" FontFamily="{StaticResource MonoFont}" FontSize="13" FontWeight="Bold" Margin="0,0,0,8"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
                <ListBox ItemsSource="{Binding Timelines}" SelectedItem="{Binding SelectedTimeline}" DisplayMemberPath="Name"/>
            </Border>
            <Border Grid.Column="2" Background="{DynamicResource BgStrip}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Horizontal timeline placeholder (keyframes + tracks)" Foreground="{DynamicResource TextSecondary}"/>
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedTimeline.Tracks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding TargetPath}" FontFamily="{StaticResource MonoFont}" FontWeight="Bold"/>
                                        <ItemsControl ItemsSource="{Binding Keyframes}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="4,0" Padding="6,4" Background="{DynamicResource BgControl}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding TimeSeconds, StringFormat='t={0:F1}s'}" FontFamily="{StaticResource MonoFont}"/>
                                                            <TextBlock Text="{Binding Value, StringFormat='v={0:F2}'}" FontFamily="{StaticResource MonoFont}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Play" Style="{StaticResource PtButton}" Command="{Binding PlayCommand}" Margin="0,0,6,0"/>
            <Button Content="Stop" Style="{StaticResource PtButton}" Command="{Binding StopCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
