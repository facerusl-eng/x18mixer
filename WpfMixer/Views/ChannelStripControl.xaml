<UserControl x:Class="WpfMixer.Views.ChannelStripControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WpfMixer.Converters"
             xmlns:views="clr-namespace:WpfMixer.Views"
             Width="74">

    <UserControl.Resources>
        <conv:BoolToMuteColorConverter  x:Key="MuteColor"/>
        <conv:BoolToMuteTextConverter   x:Key="MuteText"/>
        <conv:BoolToHighlightConverter  x:Key="Highlight"/>
        <conv:BoolToSoloColorConverter  x:Key="SoloColor"/>
        <conv:BoolToSelectBorderConverter x:Key="SelectBorder"/>
        <conv:DoubleToDbStringConverter x:Key="DbLabel"/>
    </UserControl.Resources>

    <!-- Outer: selection highlight border -->
    <Border x:Name="StripOuter"
            BorderThickness="1"
            BorderBrush="{Binding IsSelected, Converter={StaticResource SelectBorder}}"
            CornerRadius="3">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="6"/>      <!-- Color strip -->
                <RowDefinition Height="32"/>     <!-- Name + key badge -->
                <RowDefinition Height="18"/>     <!-- Pan slider -->
                <RowDefinition Height="*"/>      <!-- Fader + Meter -->
                <RowDefinition Height="26"/>     <!-- dB readout -->
                <RowDefinition Height="26"/>     <!-- Mute / Solo / Sel row -->
                <RowDefinition Height="20"/>     <!-- Momentary checkbox -->
            </Grid.RowDefinitions>

            <!-- ── Row 0: Color strip ── -->
            <Border Grid.Row="0" CornerRadius="3,3,0,0"
                    Background="{Binding ColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>

            <!-- ── Row 1: Name + key badge ── -->
            <Border Grid.Row="1" Background="#FF1E1E1E"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" Foreground="#FFE0E0E0"
                             BorderThickness="0" FontSize="11" FontWeight="SemiBold"
                             TextAlignment="Center" VerticalAlignment="Center"
                             Padding="2,0" Margin="0,0,20,0"/>
                    <!-- Key badge top-right -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="#FF2A2A2A" CornerRadius="2" Padding="2,1"
                            Margin="0,2,2,0" Cursor="Hand"
                            MouseLeftButtonUp="KeyBadge_Click">
                        <TextBlock FontSize="9" Foreground="#FF8888BB"
                                   FontFamily="{StaticResource MonoFont}"
                                   Text="{Binding AssignedKey, FallbackValue='—'}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Row 2: Pan slider ── -->
            <Grid Grid.Row="2" Background="#FF1A1A1A" Margin="4,0">
                <Slider Style="{StaticResource PanSlider}"
                        Value="{Binding Pan}"
                        VerticalAlignment="Center"/>
                <!-- Center tick mark -->
                <TextBlock Text="C" FontSize="9" Foreground="#FF555555"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>

            <!-- ── Row 3: Fader + LED meter ── -->
            <Grid Grid.Row="3" Margin="4,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>    <!-- Fader -->
                    <ColumnDefinition Width="16"/>   <!-- Meter -->
                </Grid.ColumnDefinitions>

                <!-- Fader scale marks -->
                <Canvas Grid.Column="0" IsHitTestVisible="False">
                </Canvas>

                <Slider Grid.Column="0"
                        Style="{StaticResource VerticalFader}"
                        Value="{Binding FaderLevel}"
                        HorizontalAlignment="Center"/>

                <views:LedMeterControl Grid.Column="1"
                                       Level="{Binding MeterLevel}"
                                       VerticalAlignment="Stretch"/>
            </Grid>

            <!-- ── Row 4: dB readout ── -->
            <Border Grid.Row="4" Background="#FF0D0D0D"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding FaderLevel, Converter={StaticResource DbLabel}}"
                           FontFamily="{StaticResource MonoFont}" FontSize="12"
                           Foreground="#FF00E676"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- ── Row 5: Mute / Solo / Sel ── -->
            <Grid Grid.Row="5" Background="#FF1A1A1A" Margin="3,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="18"/>
                </Grid.ColumnDefinitions>

                <!-- MUTE -->
                <Button Grid.Column="0" Content="M" Margin="1,0"
                        Style="{StaticResource MuteButton}"
                        Background="{Binding IsMuted, Converter={StaticResource MuteColor}}"
                        Foreground="White"
                        Click="Mute_Click" FontSize="10" FontWeight="Bold" Padding="0"/>

                <!-- SOLO -->
                <Button Grid.Column="1" Content="S" Margin="1,0"
                        Background="{Binding IsSolo, Converter={StaticResource SoloColor}}"
                        Foreground="#FFFFA000"
                        Style="{StaticResource SoloButton}"
                        Click="Solo_Click" FontSize="10" FontWeight="Bold" Padding="0"/>

                <!-- SELECT dot -->
                <Border Grid.Column="2" Width="14" Height="14"
                        CornerRadius="7" Margin="1,6,1,6"
                        Background="{Binding IsSelected, Converter={StaticResource SelectBorder}}"
                        BorderBrush="#FF444444" BorderThickness="1"
                        Cursor="Hand"
                        MouseLeftButtonUp="Select_Click"/>
            </Grid>

            <!-- ── Row 6: Momentary checkbox ── -->
            <CheckBox Grid.Row="6" Content="Mom" IsChecked="{Binding IsMomentaryMute}"
                      Foreground="#FF666666" FontSize="9"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- Key highlight flash overlay -->
            <Border Grid.RowSpan="7"
                    BorderThickness="2" CornerRadius="3"
                    BorderBrush="{Binding IsKeyHighlighted, Converter={StaticResource Highlight}}"
                    IsHitTestVisible="False"/>
        </Grid>
    </Border>
</UserControl>

