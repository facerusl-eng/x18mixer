<UserControl x:Class="WpfMixer.Views.BusSendStripControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WpfMixer.Converters"
             Width="72" MinHeight="390">

    <UserControl.Resources>
        <conv:BoolToMuteColorConverter x:Key="MuteColor"/>
        <conv:DoubleToDbStringConverter x:Key="DbLabel"/>
    </UserControl.Resources>

    <Border BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" CornerRadius="3">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="6"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="20"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{Binding ColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}"/>

            <Border Grid.Row="1" Background="#FF1E1E1E" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <TextBlock Text="{Binding ChannelName}" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="White" FontFamily="{StaticResource MonoFont}" FontSize="10" TextTrimming="CharacterEllipsis"/>
            </Border>

            <Slider Grid.Row="2" Style="{StaticResource VerticalFader}"
                    Value="{Binding SendLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    HorizontalAlignment="Center" Margin="0,8"/>

            <Border Grid.Row="3" Background="#FF111111" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding SendLevel, Converter={StaticResource DbLabel}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource Accent}" FontFamily="{StaticResource MonoFont}" FontSize="10"/>
            </Border>

            <Grid Grid.Row="4" Margin="3,2" Background="#FF1A1A1A">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="ON"
                        Style="{StaticResource MuteButton}"
                        Background="{Binding SendOn, Converter={StaticResource MuteColor}}"
                        Foreground="White" FontSize="9"
                        Click="OnButton_Click"/>
                <ToggleButton Grid.Column="1" Content="PRE" IsChecked="{Binding PrePost, Mode=TwoWay}"
                              Margin="1,0,0,0"
                              FontFamily="{StaticResource MonoFont}" FontSize="9"
                              Background="#FF1F1F2A" Foreground="#FFCE93D8"
                              BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
            </Grid>

            <TextBlock Grid.Row="5" Text="SEND"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{StaticResource TextSecondary}"
                       FontFamily="{StaticResource MonoFont}" FontSize="9"/>
        </Grid>
    </Border>
</UserControl>
