<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         NEON THEME  (Human Jukebox: deep dark with vivid neon accents)
         Pink / cyan / electric-blue palette
         ═══════════════════════════════════════════════════════════════════════ -->

    <Color x:Key="BgDeepColor">    #FF060610</Color>
    <Color x:Key="BgPanelColor">   #FF0E0E1E</Color>
    <Color x:Key="BgStripColor">   #FF141428</Color>
    <Color x:Key="BgControlColor"> #FF1C1C34</Color>
    <Color x:Key="BgHoverColor">   #FF252542</Color>
    <Color x:Key="BgPressColor">   #FF05050E</Color>

    <Color x:Key="BorderColor">    #FF2A2A50</Color>
    <Color x:Key="BorderFocusColor">#FF5050AA</Color>

    <!-- Main accent: hot pink / magenta -->
    <Color x:Key="AccentColor">    #FFFF2D87</Color>
    <Color x:Key="AccentDimColor"> #FF880050</Color>
    <Color x:Key="AccentGlowColor">#55FF2D87</Color>

    <Color x:Key="MuteColor">      #FFFF2020</Color>
    <Color x:Key="SoloColor">      #FFFF9F00</Color>
    <Color x:Key="SelectColor">    #FF2979FF</Color>
    <Color x:Key="ClipColor">      #FFFF2020</Color>
    <Color x:Key="WarningColor">   #FFFF9F00</Color>

    <Color x:Key="TextPrimaryColor">  #FFE8E8FF</Color>
    <Color x:Key="TextSecondaryColor">#FF7878B0</Color>
    <Color x:Key="TextDimColor">      #FF303060</Color>
    <Color x:Key="TextOnAccentColor"> #FF000000</Color>

    <!-- Fader / meter: cyan highlights -->
    <Color x:Key="FaderTrackColor">   #FF1A1A3A</Color>
    <Color x:Key="FaderThumbColor">   #FF00E5FF</Color>
    <Color x:Key="MeterGreenColor">   #FF00E676</Color>
    <Color x:Key="MeterYellowColor">  #FFFFF000</Color>
    <Color x:Key="MeterRedColor">     #FFFF2020</Color>
    <Color x:Key="MeterOffGreenColor">#FF002A14</Color>
    <Color x:Key="MeterOffYellColor"> #FF303000</Color>
    <Color x:Key="MeterOffRedColor">  #FF300808</Color>
    <Color x:Key="PeakHoldColor">     #FF00E5FF</Color>
    <Color x:Key="ClipLedColor">      #FFFF2020</Color>

    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">14</CornerRadius>
    <CornerRadius x:Key="RadiusStrip">6,6,0,0</CornerRadius>

    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                x:Key="ShadowBlurSmall">8</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                x:Key="ShadowBlurMedium">20</sys:Double>
    <Color x:Key="ShadowColor">#88FF2D87</Color>

</ResourceDictionary>
