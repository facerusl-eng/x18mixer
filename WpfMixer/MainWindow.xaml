<Window x:Class="WpfMixer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WpfMixer.Views"
        xmlns:conv="clr-namespace:WpfMixer.Converters"
        Title="X AIR X18" Height="760" Width="1440"
        WindowState="Maximized"
        MinWidth="900" MinHeight="540"
        Background="{StaticResource BgDeep}"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp"
        Closing="Window_Closing">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToHighlightConverter  x:Key="Highlight"/>
        <conv:DoubleToDbStringConverter x:Key="DbLabel"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="22"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FF1A1030" Offset="0"/>
                    <GradientStop Color="#FF0D0820" Offset="0.6"/>
                    <GradientStop Color="#FF05040B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel Margin="6,3">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <TextBlock Text="X AIR" FontSize="16" FontWeight="Bold"
                               Foreground="#FF1DB954" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBox Width="130" Text="{Binding MixerIpInput, UpdateSourceTrigger=PropertyChanged}"
                             VerticalAlignment="Center" Margin="0,0,4,0"
                             FontFamily="{StaticResource MonoFont}" ToolTip="Mixer IP address"/>
                    <Button Content="Connect" Style="{StaticResource PtButton}"
                            Command="{Binding ConnectManualCommand}"
                            Background="#FF1A2A1A" BorderBrush="#FF1DB954" Margin="0,0,4,0"/>
                    <Button Content="Discover" Style="{StaticResource PtButton}"
                            Command="{Binding DiscoverCommand}" Margin="0,0,4,0"/>
                    <Button Content="Disconnect" Style="{StaticResource PtButton}"
                            Command="{Binding DisconnectCommand}"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolVis}}"
                            Margin="0,0,4,0"/>
                    <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="4,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#FF444444"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                        <Setter Property="Fill" Value="#FF1DB954"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}" FontSize="11" Margin="6,0,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <ComboBox Width="110" VerticalAlignment="Center" Margin="0,0,4,0"
                              Background="{StaticResource BgControl}" Foreground="{StaticResource TextPrimary}"
                              BorderBrush="{StaticResource BorderBrush}"
                              SelectionChanged="Preset_SelectionChanged">
                        <ComboBoxItem Content="-- Preset --" Tag=""/>
                        <ComboBoxItem Content="Solo Singer" Tag="SoloSinger"/>
                        <ComboBoxItem Content="Acoustic Duo" Tag="AcousticDuo"/>
                        <ComboBoxItem Content="Karaoke" Tag="Karaoke"/>
                        <ComboBoxItem Content="Full Band" Tag="FullBand"/>
                        <ComboBoxItem Content="DJ Set" Tag="DjSet"/>
                    </ComboBox>
                    <Button Content="Save Scene" Style="{StaticResource PtButton}"
                            Command="{Binding SaveSceneCommand}" Margin="0,0,2,0"/>
                    <Button Content="Load Scene" Style="{StaticResource PtButton}"
                            Command="{Binding LoadSceneCommand}" Margin="0,0,2,0"/>
                    <Button Content="Undo" Style="{StaticResource PtButton}"
                            Command="{Binding UndoCommand}" Margin="0,0,2,0"/>
                    <Button Content="Redo" Style="{StaticResource PtButton}"
                            Command="{Binding RedoCommand}" Margin="0,0,8,0"/>
                    <Button Content="PERFORM" Style="{StaticResource PtButton}"
                            Command="{Binding TogglePerformanceModeCommand}"
                            BorderBrush="#FF1DB954" Margin="0,0,6,0"/>
                              <!-- Theme switcher -->
                              <ComboBox ItemsSource="{Binding Appearance.Themes}"
                                  SelectedItem="{Binding Appearance.SelectedTheme}"
                                  DisplayMemberPath="Name"
                                  Width="90" Height="24" VerticalAlignment="Center"
                                  Margin="0,0,4,0"
                                  ToolTip="Switch theme"/>
                              <Button Content="PANIC" FontWeight="Bold" FontSize="13"
                            Style="{StaticResource PtButton}"
                            Command="{Binding PanicMuteCommand}"
                            Background="#FF3A0000" BorderBrush="#FFE53935" Foreground="#FFE53935"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- MAIN TAB AREA -->
        <TabControl Grid.Row="1"
                    Background="{StaticResource BgDeep}"
                    BorderBrush="{StaticResource BorderBrush}">

            <TabControl.Style>
                <Style TargetType="TabControl">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPerformanceMode}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Style>

            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="{StaticResource BgPanel}" />
                    <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                    <Setter Property="Padding" Value="12,5" />
                    <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                    <Setter Property="FontSize" Value="11" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{StaticResource BgStrip}" />
                            <Setter Property="Foreground" Value="{StaticResource Accent}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </TabControl.Resources>

            <!-- ─── MIXER TAB ─── -->
            <TabItem Header="MIXER">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="270"/>   <!-- Control Room -->
                        <RowDefinition Height="5"/>     <!-- Splitter -->
                        <RowDefinition Height="*"/>     <!-- Fader Zone -->
                    </Grid.RowDefinitions>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- ROW 0 ▸ CONTROL ROOM                                   -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <Border Grid.Row="0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#FF1A1030" Offset="0"/>
                                <GradientStop Color="#FF0E0820" Offset="0.6"/>
                                <GradientStop Color="#FF05040B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#88A259FF" ShadowDepth="0" BlurRadius="20" Opacity="0.4"/>
                        </Border.Effect>

                        <Grid Margin="10,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>  <!-- MAIN LR master fader -->
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>    <!-- DCA / Mute / Bus / VU -->
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="160"/>  <!-- Scenes / Panic -->
                            </Grid.ColumnDefinitions>

                            <!-- Left: MAIN LR master fader -->
                            <Border Grid.Column="0"
                                    BorderBrush="{StaticResource Accent}" BorderThickness="1" CornerRadius="6"
                                    Padding="10,8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF0D1F0D" Offset="0"/>
                                        <GradientStop Color="#FF071407" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#FF1DB954" ShadowDepth="0" BlurRadius="10" Opacity="0.25"/>
                                </Border.Effect>
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="X AIR" FontFamily="{StaticResource MonoFont}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}"
                                               HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="MAIN  L/R" FontFamily="{StaticResource MonoFont}"
                                               FontSize="9" FontWeight="Bold"
                                               Foreground="{StaticResource Accent}" Opacity="0.7"
                                               HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                    <Slider Style="{StaticResource VerticalFader}"
                                            Value="{Binding MainLR.FaderLevel, Mode=TwoWay}"
                                            Height="140" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding MainLR.FaderLevel, Converter={StaticResource DbLabel}}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="13" FontWeight="Bold"
                                               Foreground="#FF00E676" HorizontalAlignment="Center" Margin="0,6,0,2"/>
                                    <TextBlock Text="{Binding StatusText}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="8"
                                               Foreground="{StaticResource TextSecondary}"
                                               HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="140"
                                               Opacity="0.6"/>
                                </StackPanel>
                            </Border>

                            <!-- Center: DCA / Mute / Bus / FX overview -->
                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="— CONTROL ROOM —"
                                           FontFamily="{StaticResource MonoFont}" FontSize="11" FontWeight="Bold"
                                           Foreground="{StaticResource Accent}" Opacity="0.55"
                                           HorizontalAlignment="Center" Margin="0,0,0,8"/>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- DCA Groups -->
                                    <Border Grid.Column="0"
                                            Background="#FF111111" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="5" Padding="10,8">
                                        <StackPanel>
                                            <TextBlock Text="DCA GROUPS" FontFamily="{StaticResource MonoFont}"
                                                       FontSize="9" Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <UniformGrid Columns="2" Rows="2">
                                                <Button Content="DCA 1" Style="{StaticResource PtButton}" Margin="3"/>
                                                <Button Content="DCA 2" Style="{StaticResource PtButton}" Margin="3"/>
                                                <Button Content="DCA 3" Style="{StaticResource PtButton}" Margin="3"/>
                                                <Button Content="DCA 4" Style="{StaticResource PtButton}" Margin="3"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Mute Groups -->
                                    <Border Grid.Column="2"
                                            Background="#FF111111" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="5" Padding="10,8">
                                        <StackPanel>
                                            <TextBlock Text="MUTE GROUPS" FontFamily="{StaticResource MonoFont}"
                                                       FontSize="9" Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <UniformGrid Columns="2" Rows="2">
                                                <Button Content="MG 1" Style="{StaticResource PtButton}" Margin="3"/>
                                                <Button Content="MG 2" Style="{StaticResource PtButton}" Margin="3"/>
                                                <Button Content="MG 3" Style="{StaticResource PtButton}" Margin="3"/>
                                                <Button Content="MG 4" Style="{StaticResource PtButton}" Margin="3"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <!-- AUX / Bus Sends -->
                                    <Border Grid.Column="4"
                                            Background="#FF111111" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" CornerRadius="5" Padding="10,8">
                                        <StackPanel>
                                            <TextBlock Text="AUX / BUS" FontFamily="{StaticResource MonoFont}"
                                                       FontSize="9" Foreground="{StaticResource TextSecondary}"
                                                       HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                            <Button Content="Bus 1" Style="{StaticResource PtButton}" Margin="1,2" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="1"/>
                                            <Button Content="Bus 2" Style="{StaticResource PtButton}" Margin="1,2" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="2"/>
                                            <Button Content="Bus 3" Style="{StaticResource PtButton}" Margin="1,2" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="3"/>
                                            <Button Content="Bus 4" Style="{StaticResource PtButton}" Margin="1,2" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="4"/>
                                            <Button Content="Bus 5" Style="{StaticResource PtButton}" Margin="1,2" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="5"/>
                                            <Button Content="Bus 6" Style="{StaticResource PtButton}" Margin="1,2" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="6"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>

                            <!-- Right: Scenes / Undo / Panic -->
                            <Border Grid.Column="4"
                                    Background="#FF111111" BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="SCENES" FontFamily="{StaticResource MonoFont}"
                                               FontSize="9" Foreground="{StaticResource TextSecondary}"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <Button Content="Save Scene" Style="{StaticResource PtButton}" Margin="1,3" Command="{Binding SaveSceneCommand}"/>
                                    <Button Content="Load Scene" Style="{StaticResource PtButton}" Margin="1,3" Command="{Binding LoadSceneCommand}"/>
                                    <Button Content="Undo" Style="{StaticResource PtButton}" Margin="1,3" Command="{Binding UndoCommand}"/>
                                    <Button Content="Redo" Style="{StaticResource PtButton}" Margin="1,3" Command="{Binding RedoCommand}"/>
                                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="0,10"/>
                                    <Button Content="PANIC" FontWeight="Bold" FontSize="13"
                                            Style="{StaticResource PtButton}"
                                            Command="{Binding PanicMuteCommand}"
                                            Background="#FF3A0000" BorderBrush="#FFE53935"
                                            Foreground="#FFE53935" Margin="1,3"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Draggable divider -->
                    <GridSplitter Grid.Row="1"
                                  HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                  Background="#FF2A1A4A" ResizeDirection="Rows" Cursor="SizeNS">
                        <GridSplitter.Effect>
                            <DropShadowEffect Color="#FF6644FF" ShadowDepth="0" BlurRadius="6" Opacity="0.5"/>
                        </GridSplitter.Effect>
                    </GridSplitter>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- ROW 2 ▸ FADER ZONE                                     -->
                    <!-- ═══════════════════════════════════════════════════════ -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>   <!-- SOF bar -->
                            <RowDefinition Height="*"/>      <!-- channel strips -->
                        </Grid.RowDefinitions>

                        <!-- SOF Selector Bar -->
                        <Border Grid.Row="0" Background="#FF13261B" BorderBrush="{StaticResource Accent}"
                                BorderThickness="1" CornerRadius="4" Padding="8,4" Margin="4,4,4,2">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                    <TextBlock Text="SOF" Foreground="{StaticResource Accent}" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <Button Content="BUS 1" Style="{StaticResource PtButton}" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="1" Margin="0,0,4,0"/>
                                    <Button Content="BUS 2" Style="{StaticResource PtButton}" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="2" Margin="0,0,4,0"/>
                                    <Button Content="BUS 3" Style="{StaticResource PtButton}" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="3" Margin="0,0,4,0"/>
                                    <Button Content="BUS 4" Style="{StaticResource PtButton}" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="4" Margin="0,0,4,0"/>
                                    <Button Content="BUS 5" Style="{StaticResource PtButton}" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="5" Margin="0,0,4,0"/>
                                    <Button Content="BUS 6" Style="{StaticResource PtButton}" Command="{Binding BusMix.SelectBusCommand}" CommandParameter="6" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SelectedSofBusIndex, StringFormat=Bus {0}}" Foreground="{StaticResource Accent}" FontFamily="{StaticResource MonoFont}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Content="ENTER SOF" Style="{StaticResource PtButton}" Command="{Binding BusMix.EnterSofCommand}" Margin="0,0,4,0"/>
                                    <Button Content="EXIT SOF" Style="{StaticResource PtButton}" Command="{Binding BusMix.ExitSofCommand}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Full-width channel strip scroll area -->
                        <ScrollViewer x:Name="MixerScroll" Grid.Row="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      Background="{StaticResource BgDeep}">
                            <Grid>
                                <!-- Normal mix -->
                                <StackPanel Orientation="Horizontal" Margin="2,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSofActive}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <ItemsControl ItemsSource="{Binding ChannelViewModels}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <views:ChannelStripControl DataContext="{Binding}"
                                                    Height="{Binding ViewportHeight, ElementName=MixerScroll}"
                                                    Margin="1,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Separator -->
                                    <Border Width="2" Background="{StaticResource BorderBrush}" Margin="4,6"/>
                                    <!-- Main LR strip -->
                                    <views:ChannelStripControl DataContext="{Binding MainLR}" Width="82"
                                        Height="{Binding ViewportHeight, ElementName=MixerScroll}"
                                        Margin="2,0"/>
                                </StackPanel>

                                <!-- SOF mix -->
                                <StackPanel Orientation="Horizontal" Margin="2,0">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSofActive}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <ItemsControl ItemsSource="{Binding BusMix.ChannelSends}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <views:BusSendStripControl Margin="1,0"
                                                    Height="{Binding ViewportHeight, ElementName=MixerScroll}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border Width="2" Background="{StaticResource BorderBrush}" Margin="4,6"/>
                                    <Border Background="{StaticResource BgStrip}" BorderBrush="{StaticResource BorderBrush}"
                                            BorderThickness="1" Width="92" Margin="2,0" Padding="8"
                                            Height="{Binding ViewportHeight, ElementName=MixerScroll}">
                                        <StackPanel>
                                            <TextBlock Text="BUS MASTER" HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" FontWeight="Bold"/>
                                            <Slider Style="{StaticResource VerticalFader}" Value="{Binding BusMix.BusMasterLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                            <ToggleButton IsChecked="{Binding BusMix.BusMasterMute, Mode=TwoWay}" Content="MUTE" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─── FX RACK TAB ─── -->
            <TabItem Header="FX RACK">
                <views:FxRackView DataContext="{Binding FxRack}" />
            </TabItem>

            <!-- ─── BUS MIX TAB ─── -->
            <TabItem Header="BUS MIX">
                <views:BusMixView DataContext="{Binding BusMix}" />
            </TabItem>

            <!-- ─── MONITOR MIX TAB ─── -->
            <TabItem Header="MONITOR MIX">
                <views:MonitorMixView DataContext="{Binding MonitorMix}" />
            </TabItem>

            <!-- ─── SCENES TAB ─── -->
            <TabItem Header="SCENES">
                <views:SceneManagerView DataContext="{Binding SceneManager}" />
            </TabItem>

            <!-- ─── ROUTING TAB ─── -->
            <TabItem Header="ROUTING">
                <views:RoutingView DataContext="{Binding}" />
            </TabItem>

            <!-- ─── REMOTE CONTROL TAB ─── -->
            <TabItem Header="REMOTE">
                <views:RemoteControlView DataContext="{Binding RemoteControl}" />
            </TabItem>

                <!-- ─── APPEARANCE / SETTINGS TAB ─── -->
                <TabItem Header="APPEARANCE">
                    <views:AppearancePanel DataContext="{Binding Appearance}"/>
                </TabItem>

                <TabItem Header="PLUGINS">
                    <views:PluginsPanel DataContext="{Binding PluginsFeature}"/>
                </TabItem>

                <TabItem Header="SCRIPTING">
                    <views:ScriptingPanel DataContext="{Binding ScriptingFeature}"/>
                </TabItem>

                <TabItem Header="AUTOMATION">
                    <views:AutomationPanel DataContext="{Binding AutomationFeature}"/>
                </TabItem>

                <TabItem Header="MACROS">
                    <views:MacrosPanel DataContext="{Binding MacrosFeature}"/>
                </TabItem>

                <TabItem Header="ADVANCED">
                    <views:AdvancedSettingsPanel DataContext="{Binding AdvancedSettingsFeature}"/>
                </TabItem>

        </TabControl>

        <views:PerformanceView Grid.Row="1" DataContext="{Binding Performance}">
            <views:PerformanceView.Style>
                <Style TargetType="views:PerformanceView">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsPerformanceMode}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </views:PerformanceView.Style>
        </views:PerformanceView>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#FF0A0A0A"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="8,2">
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="#DD1DB954" CornerRadius="6" Padding="16,4"
                        Visibility="{Binding ShowKeyOverlay, Converter={StaticResource BoolVis}}">
                    <TextBlock Text="{Binding OverlayText}" Foreground="Black"
                               FontSize="13" FontWeight="Bold" FontFamily="{StaticResource MonoFont}"/>
                </Border>
                <TextBlock Text="{Binding Mixer.MixerName}" HorizontalAlignment="Right"
                           Foreground="{StaticResource TextSecondary}" FontSize="11" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
