<Application x:Class="WpfMixer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:conv="clr-namespace:WpfMixer.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Active theme — swapped at runtime by ThemeService -->
                <ResourceDictionary Source="pack://application:,,,/WpfMixer;component/Themes/Dark.xaml"/>
                <!-- Animation helpers (easing curves + button/tab styles) -->
                <ResourceDictionary Source="pack://application:,,,/WpfMixer;component/Themes/Animations.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ══ DERIVED BRUSHES (rebuilt by ThemeService on theme switch) ════ -->
            <SolidColorBrush x:Key="BgDeep"          Color="{DynamicResource BgDeepColor}"/>
            <SolidColorBrush x:Key="BgPanel"         Color="{DynamicResource BgPanelColor}"/>
            <SolidColorBrush x:Key="BgStrip"         Color="{DynamicResource BgStripColor}"/>
            <SolidColorBrush x:Key="BgControl"       Color="{DynamicResource BgControlColor}"/>
            <SolidColorBrush x:Key="BorderBrush"     Color="{DynamicResource BorderColor}"/>
            <SolidColorBrush x:Key="Accent"          Color="{DynamicResource AccentColor}"/>
            <SolidColorBrush x:Key="MuteBrush"       Color="{DynamicResource MuteColor}"/>
            <SolidColorBrush x:Key="SoloBrush"       Color="{DynamicResource SoloColor}"/>
            <SolidColorBrush x:Key="SelectBrush"     Color="{DynamicResource SelectColor}"/>
            <SolidColorBrush x:Key="TextPrimary"     Color="{DynamicResource TextPrimaryColor}"/>
            <SolidColorBrush x:Key="TextSecondary"   Color="{DynamicResource TextSecondaryColor}"/>
            <SolidColorBrush x:Key="FaderTrackBrush" Color="{DynamicResource FaderTrackColor}"/>

            <!-- ══ TYPOGRAPHY ════════════════════════════════════════════════════ -->
            <FontFamily x:Key="UIFont">Segoe UI, Arial</FontFamily>
            <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, Courier New</FontFamily>
            <FontFamily x:Key="HeadingFont">Segoe UI Semibold, Segoe UI, Arial</FontFamily>
            <sys:Double x:Key="GlobalFontSize">12</sys:Double>

            <!-- ══ WINDOW ═════════════════════════════════════════════════════════ -->
            <Style TargetType="Window">
                <Setter Property="Background"  Value="{DynamicResource BgDeep}"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="FontFamily"  Value="{StaticResource UIFont}"/>
                <Setter Property="FontSize"    Value="{DynamicResource GlobalFontSize}"/>
            </Style>

            <!-- ══ SCROLLBAR (slim dark) ══════════════════════════════════════════ -->
            <Style x:Key="ScrollBarLineButtonStyle" TargetType="RepeatButton">
                <Setter Property="Background" Value="{DynamicResource BgControl}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="rb" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="rb" Property="Background" Value="{DynamicResource BgHoverColor}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="rb" Property="Background" Value="{DynamicResource BgPressColor}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="tb"
                                    Background="{DynamicResource Accent}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="tb" Property="Background" Value="{DynamicResource AccentDimColor}"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="tb" Property="Background" Value="{DynamicResource AccentColor}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
                <Setter Property="Width" Value="8"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Grid Background="{TemplateBinding Background}">
                                <Grid.Resources>
                                    <Style TargetType="RepeatButton" BasedOn="{StaticResource ScrollBarLineButtonStyle}"/>
                                </Grid.Resources>

                                <Grid x:Name="VerticalRoot">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="14"/>
                                    </Grid.RowDefinitions>
                                    <RepeatButton Grid.Row="0" Command="ScrollBar.LineUpCommand">
                                        <Path Data="M 2 6 L 6 2 L 10 6"
                                              Stroke="{DynamicResource TextSecondary}"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </RepeatButton>
                                    <Track Grid.Row="1" x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0.15"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}" MinHeight="24"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0.15"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    <RepeatButton Grid.Row="2" Command="ScrollBar.LineDownCommand">
                                        <Path Data="M 2 2 L 6 6 L 10 2"
                                              Stroke="{DynamicResource TextSecondary}"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </RepeatButton>
                                </Grid>

                                <Grid x:Name="HorizontalRoot" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="14"/>
                                    </Grid.ColumnDefinitions>
                                    <RepeatButton Grid.Column="0" Command="ScrollBar.LineLeftCommand">
                                        <Path Data="M 6 2 L 2 6 L 6 10"
                                              Stroke="{DynamicResource TextSecondary}"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </RepeatButton>
                                    <Track Grid.Column="1" x:Name="PART_Track_H">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageLeftCommand" Opacity="0.15"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollBarThumbStyle}" MinWidth="24"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="ScrollBar.PageRightCommand" Opacity="0.15"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                    <RepeatButton Grid.Column="2" Command="ScrollBar.LineRightCommand">
                                        <Path Data="M 2 2 L 6 6 L 2 10"
                                              Stroke="{DynamicResource TextSecondary}"
                                              StrokeThickness="1.6"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                                    </RepeatButton>
                                </Grid>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Orientation" Value="Horizontal">
                                    <Setter TargetName="VerticalRoot" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="HorizontalRoot" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ BUTTON – base ════════════════════════════════════════════════ -->
            <Style x:Key="PtButton" TargetType="Button">
                <Setter Property="Background"       Value="{DynamicResource BgControl}"/>
                <Setter Property="Foreground"       Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush"      Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="Padding"          Value="8,4"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FontSize"         Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource RadiusSmall}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHoverColor}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource BgPressColor}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- MUTE button -->
            <Style x:Key="MuteButton" TargetType="Button" BasedOn="{StaticResource PtButton}">
                <Setter Property="Background"   Value="#FF3A1A1A"/>
                <Setter Property="BorderBrush"  Value="#FF7A1A1A"/>
                <Setter Property="Foreground"   Value="#FFCC4444"/>
                <Setter Property="FontWeight"   Value="Bold"/>
            </Style>
            <Style x:Key="MuteButtonActive" TargetType="Button" BasedOn="{StaticResource PtButton}">
                <Setter Property="Background"   Value="{DynamicResource MuteBrush}"/>
                <Setter Property="BorderBrush"  Value="#FFFF5252"/>
                <Setter Property="Foreground"   Value="White"/>
                <Setter Property="FontWeight"   Value="Bold"/>
            </Style>

            <!-- SOLO button -->
            <Style x:Key="SoloButton" TargetType="Button" BasedOn="{StaticResource PtButton}">
                <Setter Property="Background"   Value="#FF3A2A00"/>
                <Setter Property="BorderBrush"  Value="#FF7A5A00"/>
                <Setter Property="Foreground"   Value="#FFCC8800"/>
                <Setter Property="FontWeight"   Value="Bold"/>
            </Style>
            <Style x:Key="SoloButtonActive" TargetType="Button" BasedOn="{StaticResource PtButton}">
                <Setter Property="Background"   Value="{DynamicResource SoloBrush}"/>
                <Setter Property="Foreground"   Value="Black"/>
                <Setter Property="FontWeight"   Value="Bold"/>
            </Style>

            <!-- ══ VERTICAL FADER SLIDER ══════════════════════════════════════════ -->
            <Style x:Key="VerticalFader" TargetType="Slider">
                <Setter Property="Orientation"  Value="Vertical"/>
                <Setter Property="Minimum"      Value="0"/>
                <Setter Property="Maximum"      Value="1"/>
                <Setter Property="SmallChange"  Value="0.01"/>
                <Setter Property="LargeChange"  Value="0.05"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Track -->
                                <Border Grid.Row="1" Width="4" HorizontalAlignment="Center"
                                        Background="{DynamicResource FaderTrackBrush}"
                                        CornerRadius="2"/>
                                <!-- Unity mark -->
                                <Border Grid.Row="1" Width="10" Height="2"
                                        Background="#FF555555" HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Margin="0,-20,0,0"/>
                                <Track Grid.Row="1" x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                      Background="Transparent" BorderThickness="0" Opacity="0"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb x:Name="thumb">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Width="36" Height="14" CornerRadius="2">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#FFD0D0D0" Offset="0"/>
                                                                <GradientStop Color="#FF888888" Offset="0.5"/>
                                                                <GradientStop Color="#FFAAAAAA" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border Height="2" Width="24"
                                                                Background="#FF333333"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                      Background="Transparent" BorderThickness="0" Opacity="0"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ PAN SLIDER (horizontal, thin) ══════════════════════════════════ -->
            <Style x:Key="PanSlider" TargetType="Slider">
                <Setter Property="Orientation"  Value="Horizontal"/>
                <Setter Property="Minimum"      Value="0"/>
                <Setter Property="Maximum"      Value="1"/>
                <Setter Property="Height"       Value="20"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <Border Height="3" VerticalAlignment="Center"
                                        Background="{DynamicResource FaderTrackBrush}" CornerRadius="1"/>
                                <Border Width="2" Height="8" HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Background="#FF555555"/>
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                      Background="Transparent" BorderThickness="0" Opacity="0"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse Width="12" Height="12">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop Color="#FFE0E0E0" Offset="0"/>
                                                                <GradientStop Color="#FF888888" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                      Background="Transparent" BorderThickness="0" Opacity="0"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ TEXTBOX ══════════════════════════════════════════════════════ -->
            <Style TargetType="TextBox">
                <Setter Property="Background"  Value="{DynamicResource BgControl}"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="CaretBrush"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Padding"     Value="4,2"/>
            </Style>

            <!-- ══ LABEL / TEXTBLOCK ══════════════════════════════════════════════ -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            </Style>
            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            </Style>

            <!-- ══ SCROLLVIEWER ════════════════════════════════════════════════ -->
            <Style TargetType="ScrollViewer">
                <Setter Property="Background" Value="Transparent"/>
            </Style>

            <!-- ══ SHARED CONVERTER INSTANCES ══════════════════════════════════ -->
            <conv:DoubleToDbStringConverter x:Key="DoubleToDbStr"/>
            <conv:EnumToBoolConverter       x:Key="EnumToBool"/>

            <!-- ══ COMBOBOX ITEM ═════════════════════════════════════════════════ -->
            <Style TargetType="ComboBoxItem">
                <Setter Property="Background"  Value="{DynamicResource BgPanel}"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Padding"     Value="8,5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgHoverColor}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentGlowColor}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ COMBOBOX ══════════════════════════════════════════════════════ -->
            <Style TargetType="ComboBox">
                <Setter Property="Background"       Value="{DynamicResource BgControl}"/>
                <Setter Property="Foreground"       Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush"      Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="Padding"          Value="6,4"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="toggleBtn"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              Focusable="False"
                                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="tbBorder"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="{DynamicResource RadiusSmall}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ContentPresenter Grid.Column="0" Margin="8,4,2,4"
                                                                      HorizontalAlignment="Left"
                                                                      VerticalAlignment="Center"/>
                                                    <Path Grid.Column="1"
                                                          Data="M 2 4 L 6 8 L 10 4"
                                                          Stroke="{DynamicResource TextSecondary}"
                                                          StrokeThickness="1.5"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="tbBorder" Property="Background" Value="{DynamicResource BgHoverColor}"/>
                                                    <Setter TargetName="tbBorder" Property="BorderBrush" Value="{DynamicResource BorderFocusColor}"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="tbBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter x:Name="contentPresenter"
                                                  Margin="8,4,24,4"
                                                  IsHitTestVisible="False"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                                <Popup x:Name="PART_Popup"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       PopupAnimation="Slide"
                                       Placement="Bottom">
                                    <Border x:Name="popupBorder"
                                            Background="{DynamicResource BgPanel}"
                                            BorderBrush="{DynamicResource BorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="{DynamicResource RadiusSmall}"
                                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer>
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ LISTBOX ITEM ══════════════════════════════════════════════════ -->
            <Style TargetType="ListBoxItem">
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Padding"     Value="8,5"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="{DynamicResource RadiusSmall}"
                                    Margin="2,1">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgHoverColor}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource AccentGlowColor}"/>
                                    <Setter TargetName="bg" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ LISTBOX ════════════════════════════════════════════════════════ -->
            <Style TargetType="ListBox">
                <Setter Property="Background"       Value="{DynamicResource BgPanel}"/>
                <Setter Property="Foreground"       Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush"      Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="Padding"          Value="2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource RadiusSmall}"
                                    Padding="{TemplateBinding Padding}">
                                <ScrollViewer>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ CONTEXT MENU ══════════════════════════════════════════════════ -->
            <Style TargetType="ContextMenu">
                <Setter Property="Background"      Value="{DynamicResource BgPanel}"/>
                <Setter Property="Foreground"      Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="2"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource RadiusSmall}"
                                    Padding="{TemplateBinding Padding}">
                                <ItemsPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ MENU ITEM ══════════════════════════════════════════════════════ -->
            <Style TargetType="MenuItem">
                <Setter Property="Background"  Value="Transparent"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Padding"     Value="10,6"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="bg"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}"
                                    CornerRadius="{DynamicResource RadiusSmall}"
                                    Margin="2,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Icon"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto" SharedSizeGroup="Shortcut"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      x:Name="Icon"
                                                      ContentSource="Icon"
                                                      Width="16" Height="16"
                                                      Margin="0,0,6,0"
                                                      VerticalAlignment="Center"/>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      VerticalAlignment="Center"
                                                      RecognizesAccessKey="True"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{TemplateBinding InputGestureText}"
                                               Foreground="{DynamicResource TextSecondary}"
                                               Margin="16,0,4,0"
                                               VerticalAlignment="Center"/>
                                    <Path Grid.Column="3"
                                          x:Name="arrow"
                                          Data="M 2 4 L 6 8 L 10 4"
                                          Stroke="{DynamicResource TextSecondary}"
                                          StrokeThickness="1.5"
                                          Margin="4,0,0,0"
                                          VerticalAlignment="Center"
                                          Visibility="Collapsed"/>
                                    <Popup x:Name="PART_Popup"
                                           IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="Fade"
                                           Placement="Right">
                                        <Border Background="{DynamicResource BgPanel}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="{DynamicResource RadiusSmall}"
                                                Padding="2">
                                            <ItemsPresenter/>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource BgHoverColor}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="{DynamicResource TextDimColor}"/>
                                </Trigger>
                                <Trigger Property="Role" Value="TopLevelHeader">
                                    <Setter TargetName="arrow" Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                                <Trigger Property="Role" Value="SubmenuHeader">
                                    <Setter TargetName="arrow" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ SEPARATOR (inside menus/toolbars) ════════════════════════════ -->
            <Style TargetType="Separator">
                <Setter Property="Background"  Value="{DynamicResource BorderBrush}"/>
                <Setter Property="Height"      Value="1"/>
                <Setter Property="Margin"      Value="4,3"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>

