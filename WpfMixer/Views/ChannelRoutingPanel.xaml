<UserControl x:Class="WpfMixer.Views.ChannelRoutingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:WpfMixer.Models"
             xmlns:conv="clr-namespace:WpfMixer.Converters"
             xmlns:local="clr-namespace:WpfMixer.Views"
             Width="110"
             Background="{StaticResource BgStrip}">

    <UserControl.Resources>
        <!-- Small label style -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Margin" Value="4,4,4,2" />
        </Style>

        <!-- Toggle button (on/off) -->
        <Style x:Key="RouteToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="#1A1A1A" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="{StaticResource Accent}" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Pre/Post toggle -->
        <Style x:Key="PreToggle" TargetType="ToggleButton" BasedOn="{StaticResource RouteToggle}">
            <Setter Property="Width" Value="28" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#9C27B0" />
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="BorderBrush" Value="#9C27B0" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Send level slider -->
        <Style x:Key="SendSlider" TargetType="Slider">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="SmallChange" Value="0.01" />
            <Setter Property="LargeChange" Value="0.05" />
            <Setter Property="Orientation" Value="Horizontal" />
            <Setter Property="Height" Value="16" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="1"
            CornerRadius="2">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- ── Color strip + channel name ── -->
                <Border Height="5"
                        Background="{Binding ColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}" />
                <TextBlock Text="{Binding Name}"
                           Foreground="White" FontFamily="{StaticResource MonoFont}" FontSize="10"
                           FontWeight="Bold" TextAlignment="Center" Margin="2,3,2,3"
                           TextTrimming="CharacterEllipsis" />

                <!-- ════ INPUT SOURCE ════ -->
                <TextBlock Text="SRC" Style="{StaticResource SectionLabel}" />
                <Border Background="{StaticResource BgPanel}" Margin="4,0,4,4"
                        CornerRadius="2" Padding="4,3">
                    <StackPanel>
                        <ComboBox SelectedItem="{Binding InputSource, Mode=TwoWay}"
                                  ItemsSource="{x:Static local:ChannelRoutingPanel.InputSources}"
                                  FontFamily="{StaticResource MonoFont}" FontSize="9"
                                  Background="{StaticResource BgControl}"
                                  Foreground="{StaticResource TextSecondary}"
                                  BorderBrush="{StaticResource BorderBrush}"
                                  Height="22" Margin="0,0,0,3" />

                        <!-- Analog input number -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="IN:" Grid.Column="0" Margin="0,0,4,0"
                                       Style="{StaticResource SectionLabel}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding AnalogInput, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Background="{StaticResource BgControl}"
                                     Foreground="{StaticResource TextSecondary}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     FontFamily="{StaticResource MonoFont}" FontSize="10"
                                     Height="20" TextAlignment="Center" />
                        </Grid>

                        <!-- USB return number -->
                        <Grid Margin="0,3,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="USB:" Grid.Column="0" Margin="0,0,4,0"
                                       Style="{StaticResource SectionLabel}" VerticalAlignment="Center" />
                            <TextBox Grid.Column="1" Text="{Binding UsbReturn, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Background="{StaticResource BgControl}"
                                     Foreground="{StaticResource TextSecondary}"
                                     BorderBrush="{StaticResource BorderBrush}"
                                     FontFamily="{StaticResource MonoFont}" FontSize="10"
                                     Height="20" TextAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ════ DIRECT OUT ROUTING ════ -->
                <TextBlock Text="DIRECT OUT" Style="{StaticResource SectionLabel}" />
                <Border Background="{StaticResource BgPanel}" Margin="4,0,4,4"
                        CornerRadius="2" Padding="4,3">
                    <ComboBox SelectedItem="{Binding DirectOutSource, Mode=TwoWay}"
                              ItemsSource="{x:Static local:ChannelRoutingPanel.OutputSources}"
                              FontFamily="{StaticResource MonoFont}" FontSize="9"
                              Background="{StaticResource BgControl}"
                              Foreground="{StaticResource TextSecondary}"
                              BorderBrush="{StaticResource BorderBrush}"
                              Height="22" />
                </Border>

                <!-- ════ MAIN LR SEND ════ -->
                <TextBlock Text="MAIN LR" Style="{StaticResource SectionLabel}" />
                <Border Background="{StaticResource BgPanel}" Margin="4,0,4,4"
                        CornerRadius="2" Padding="4,3">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ToggleButton Style="{StaticResource RouteToggle}"
                                      IsChecked="{Binding SendToLr, Mode=TwoWay}"
                                      Content="LR ON" Width="52" />
                        <Slider Style="{StaticResource SendSlider}"
                                Value="{Binding Pan, Mode=TwoWay}"
                                Minimum="0" Maximum="1" Width="42" Margin="4,0,0,0"
                                ToolTip="Pan" />
                    </StackPanel>
                </Border>

                <!-- ════ BUS SENDS 1-6 ════ -->
                <TextBlock Text="BUS SENDS" Style="{StaticResource SectionLabel}" />
                <ItemsControl ItemsSource="{Binding BusSends}" Margin="4,0,4,2">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:BusSend}">
                            <DataTemplate.Resources>
                                <conv:BoolToVisibilityConverter x:Key="BoolVis" />
                            </DataTemplate.Resources>
                            <!-- Only show Bus 1-6 (BusIndex <= 6) -->
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BusIndex, Converter={x:Static local:ChannelRoutingPanel.IsBusConverter}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="24" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               Foreground="{StaticResource TextSecondary}"
                                               FontFamily="{StaticResource MonoFont}" FontSize="8"
                                               VerticalAlignment="Center" />
                                    <Slider Grid.Column="1" Style="{StaticResource SendSlider}"
                                            Value="{Binding Level, Mode=TwoWay}" />
                                    <ToggleButton Grid.Column="2" Style="{StaticResource RouteToggle}"
                                                  IsChecked="{Binding IsOn, Mode=TwoWay}"
                                                  Content="ON" FontSize="8" Padding="2,1" />
                                    <ToggleButton Grid.Column="3" Style="{StaticResource PreToggle}"
                                                  IsChecked="{Binding IsPre, Mode=OneWay}"
                                                  Click="BusSendPre_Click"
                                                  Content="PRE" FontSize="7" Padding="1" />
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- ════ FX SENDS 1-4 ════ -->
                <TextBlock Text="FX SENDS" Style="{StaticResource SectionLabel}" Margin="4,6,4,2" />
                <ItemsControl ItemsSource="{Binding BusSends}" Margin="4,0,4,4">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:BusSend}">
                            <StackPanel>
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BusIndex, Converter={x:Static local:ChannelRoutingPanel.IsFxConverter}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Grid Margin="0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="28" />
                                        <ColumnDefinition Width="24" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Label}"
                                               Foreground="#CE93D8"
                                               FontFamily="{StaticResource MonoFont}" FontSize="8"
                                               VerticalAlignment="Center" />
                                    <Slider Grid.Column="1" Style="{StaticResource SendSlider}"
                                            Value="{Binding Level, Mode=TwoWay}" />
                                    <ToggleButton Grid.Column="2" Style="{StaticResource RouteToggle}"
                                                  IsChecked="{Binding IsOn, Mode=TwoWay}"
                                                  Content="ON" FontSize="8" Padding="2,1" />
                                    <ToggleButton Grid.Column="3" Style="{StaticResource PreToggle}"
                                                  IsChecked="{Binding IsPre, Mode=OneWay}"
                                                  Click="BusSendPre_Click"
                                                  Content="PRE" FontSize="7" Padding="1" />
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
