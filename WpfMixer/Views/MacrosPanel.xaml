<UserControl x:Class="WpfMixer.Views.MacrosPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDeep}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
            <ListBox ItemsSource="{Binding MacroItems}" SelectedItem="{Binding SelectedMacro}" DisplayMemberPath="Name"/>
        </Border>
        <Border Grid.Column="2" Background="{DynamicResource BgStrip}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
            <StackPanel>
                <TextBlock Text="{Binding SelectedMacro.Name}" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,0,0,8"/>
                <ItemsControl ItemsSource="{Binding SelectedMacro.Actions}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="6" Margin="0,0,0,6" Background="{DynamicResource BgControl}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <TextBlock Text="{Binding Type}"/>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="Run Macro" Command="{Binding RunSelectedCommand}" Style="{StaticResource PtButton}" Width="120"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
