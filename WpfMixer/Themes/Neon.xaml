<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         NEON THEME  — matches Human Jukebox exactly
         canvas #05040b · panels #100a1d/#16102a · pink #ff4f9a · cyan #00c2ff
         purple #a259ff · ink #edf3ff · borders rgba(162,89,255,0.36)
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- Background hierarchy -->
    <Color x:Key="BgDeepColor">    #FF05040B</Color>
    <Color x:Key="BgPanelColor">   #FF100A1D</Color>
    <Color x:Key="BgStripColor">   #FF16102A</Color>
    <Color x:Key="BgControlColor"> #FF1C1530</Color>
    <Color x:Key="BgHoverColor">   #FF231A3A</Color>
    <Color x:Key="BgPressColor">   #FF030208</Color>

    <!-- Borders: purple tint matching Human Jukebox panel-border -->
    <Color x:Key="BorderColor">    #5CA259FF</Color>
    <Color x:Key="BorderFocusColor">#ABA259FF</Color>

    <!-- Main accent: neon pink #ff4f9a -->
    <Color x:Key="AccentColor">    #FFFF4F9A</Color>
    <Color x:Key="AccentDimColor"> #FF8A1A4A</Color>
    <Color x:Key="AccentGlowColor">#55FF4F9A</Color>

    <!-- Status: neon red, orange, cyan-blue -->
    <Color x:Key="MuteColor">      #FFFF5A5F</Color>
    <Color x:Key="SoloColor">      #FFFF9F43</Color>
    <Color x:Key="SelectColor">    #FF00C2FF</Color>
    <Color x:Key="ClipColor">      #FFFF5A5F</Color>
    <Color x:Key="WarningColor">   #FFFF9F43</Color>

    <!-- Text: ink #edf3ff / ink-soft #b5b2de -->
    <Color x:Key="TextPrimaryColor">  #FFEDF3FF</Color>
    <Color x:Key="TextSecondaryColor">#FFB5B2DE</Color>
    <Color x:Key="TextDimColor">      #FF4A4470</Color>
    <Color x:Key="TextOnAccentColor"> #FF000000</Color>

    <!-- Fader / meter: cyan #00c2ff thumb -->
    <Color x:Key="FaderTrackColor">   #FF160F28</Color>
    <Color x:Key="FaderThumbColor">   #FF00C2FF</Color>
    <Color x:Key="MeterGreenColor">   #FF00E676</Color>
    <Color x:Key="MeterYellowColor">  #FFFFF000</Color>
    <Color x:Key="MeterRedColor">     #FFFF5A5F</Color>
    <Color x:Key="MeterOffGreenColor">#FF002A14</Color>
    <Color x:Key="MeterOffYellColor"> #FF303000</Color>
    <Color x:Key="MeterOffRedColor">  #FF380A10</Color>
    <Color x:Key="PeakHoldColor">     #FF00C2FF</Color>
    <Color x:Key="ClipLedColor">      #FFFF5A5F</Color>

    <!-- Corner radii -->
    <CornerRadius x:Key="RadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">14</CornerRadius>
    <CornerRadius x:Key="RadiusStrip">6,6,0,0</CornerRadius>

    <!-- Drop shadow: pink glow -->
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                x:Key="ShadowBlurSmall">8</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                x:Key="ShadowBlurMedium">24</sys:Double>
    <Color x:Key="ShadowColor">#88FF4F9A</Color>

</ResourceDictionary>
