<UserControl x:Class="WpfMixer.Views.SceneManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeep}">

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="SCENE MANAGER" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Foreground="White" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding Status}" Foreground="{StaticResource Accent}" FontFamily="{StaticResource MonoFont}"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Margin="0,8,0,8" Background="{StaticResource BgStrip}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <ListBox ItemsSource="{Binding Scenes}" SelectedItem="{Binding SelectedScene, Mode=TwoWay}" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4" Padding="8" Background="#22111111" BorderBrush="#33333333" BorderThickness="1" CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Foreground="White"/>
                                        <TextBlock Text="{Binding Notes}" Foreground="{StaticResource TextSecondary}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm}" Foreground="{StaticResource TextSecondary}" FontFamily="{StaticResource MonoFont}" FontSize="11" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding NewSceneName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1" Text="Transition" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" Margin="0,0,6,0"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding TransitionOptions}"
                              DisplayMemberPath="Label"
                              SelectedItem="{Binding SelectedTransition, Mode=TwoWay}"
                              ToolTip="Scene load behavior&#10;Smooth: fader, pan, sends, FX parameters&#10;Instant: mute, routing, source, FX type"
                              Margin="0,0,8,0"/>
                    <Button Grid.Column="3" Content="Save Scene" Style="{StaticResource PtButton}" Command="{Binding SaveSceneCommand}" Margin="0,0,6,0"/>
                    <Button Grid.Column="4" Content="Load Scene" Style="{StaticResource PtButton}" Command="{Binding LoadSceneCommand}" Margin="0,0,6,0"/>
                    <Button Grid.Column="5" Content="Rename" Style="{StaticResource PtButton}" Command="{Binding RenameSceneCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8">
                <TextBlock Text="SCENE PREVIEW" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Foreground="White"/>
            </Border>

            <Border Grid.Row="1" Margin="0,8,0,8" Background="{StaticResource BgStrip}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedScene.Name, TargetNullValue=No scene selected}" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" FontSize="15" Foreground="White"/>
                    <TextBlock Text="{Binding SelectedScene.Timestamp, StringFormat=Timestamp: {0:yyyy-MM-dd HH:mm:ss}}" Foreground="{StaticResource TextSecondary}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding SelectedScene.Notes, StringFormat=Notes: {0}}" Foreground="{StaticResource TextSecondary}" Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding SelectedScene.ChannelCount, StringFormat=Channels: {0}}" Foreground="{StaticResource Accent}" FontFamily="{StaticResource MonoFont}" Margin="0,12,0,0"/>
                    <TextBlock Text="{Binding SelectedScene.FxTypes, StringFormat=FX: {0}}" Foreground="{StaticResource Accent}" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SelectedScene.RoutingSummary, StringFormat=Routing: {0}}" Foreground="{StaticResource Accent}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8">
                <WrapPanel>
                    <Button Content="Delete" Style="{StaticResource PtButton}" Command="{Binding DeleteSceneCommand}" Margin="0,0,6,0"/>
                    <Button Content="Import" Style="{StaticResource PtButton}" Click="Import_Click" Margin="0,0,6,0"/>
                    <Button Content="Export" Style="{StaticResource PtButton}" Click="Export_Click" Margin="0,0,6,0"/>
                    <Button Content="Create Preset" Style="{StaticResource PtButton}" Click="CreatePreset_Click" Margin="0,0,6,0"/>
                    <Button Content="Refresh" Style="{StaticResource PtButton}" Command="{Binding RefreshScenesCommand}"/>
                </WrapPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
