<UserControl x:Class="WpfMixer.Views.FxRackView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgDeep}">

    <UserControl.Resources>
        <Style TargetType="ListBoxItem" x:Key="FxSlotItemStyle">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#FF1E1E1E"/>
            <Setter Property="BorderBrush" Value="#FF3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="SlotBorder"
                                CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="9" Height="9" Margin="0,0,8,0" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="#FF555555"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOn}" Value="True">
                                                    <Setter Property="Fill" Value="{StaticResource Accent}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Grid.Column="1" Text="{Binding SlotLabel}" FontFamily="{StaticResource MonoFont}" FontSize="12" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SlotBorder" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter TargetName="SlotBorder" Property="Background" Value="#FF15241A"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SlotBorder" Property="Background" Value="#FF2B2B2B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToggleButton" x:Key="FxOnToggleStyle">
            <Setter Property="Background" Value="#FF241414"/>
            <Setter Property="BorderBrush" Value="#FF7A2B2B"/>
            <Setter Property="Foreground" Value="#FFFF8888"/>
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="OnBorder"
                                CornerRadius="4"
                                BorderThickness="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                Padding="8,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OnBorder" Property="Background" Value="#FF16331D"/>
                                <Setter TargetName="OnBorder" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OnBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ListBox Grid.Row="0"
                 ItemsSource="{Binding Slots}"
                 SelectedItem="{Binding SelectedFxSlot, Mode=TwoWay}"
                 ItemContainerStyle="{StaticResource FxSlotItemStyle}"
                 BorderThickness="0"
                 Background="Transparent"
                 HorizontalAlignment="Left"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>

        <Border Grid.Row="1" Margin="0,12,0,0"
                Background="#FF151515"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                Padding="12" Opacity="0">
            <Border.Triggers>
                <EventTrigger RoutedEvent="Border.Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.25"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="FX TYPE" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextSecondary}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox Width="260"
                              ItemsSource="{Binding AvailableFxTypes}"
                              SelectedItem="{Binding SelectedFxSlot.FxType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Background="{StaticResource BgControl}"
                              Foreground="{StaticResource TextPrimary}"
                              BorderBrush="{StaticResource BorderBrush}"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="FX RETURN" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextSecondary}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <ToggleButton IsChecked="{Binding SelectedFxSlot.IsOn, Mode=TwoWay}"
                                  Content="ON"
                                  Width="70"
                                  Style="{StaticResource FxOnToggleStyle}"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Grid.Column="0" Margin="0,12,12,0"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding SelectedFxSlot.Parameters}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" ItemWidth="168" ItemHeight="96"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FF1E1E1E" BorderBrush="#FF303030" BorderThickness="1" CornerRadius="5" Margin="4" Padding="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Text="{Binding Name}" FontFamily="{StaticResource MonoFont}" FontSize="11" Foreground="{StaticResource TextPrimary}"/>
                                        <Slider Grid.Row="1" Margin="0,8,0,6"
                                                Minimum="{Binding Min}" Maximum="{Binding Max}"
                                                Value="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                Height="32"/>
                                        <TextBlock Grid.Row="2" Text="{Binding Value, StringFormat=F2}"
                                                   HorizontalAlignment="Right" FontFamily="{StaticResource MonoFont}"
                                                   Foreground="{StaticResource Accent}" FontSize="10"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="1" Grid.Column="1" Margin="0,12,0,0"
                        Background="#FF101010" BorderBrush="#FF2D2D2D" BorderThickness="1" CornerRadius="5" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="RETURN LEVEL" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"/>
                        <Slider Grid.Row="1" Margin="0,8,0,8" Style="{StaticResource VerticalFader}"
                                Value="{Binding SelectedFxSlot.ReturnLevel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                HorizontalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Text="{Binding SelectedFxSlot.ReturnLevel, Converter={StaticResource DoubleToDbStr}}"
                                   HorizontalAlignment="Center" FontFamily="{StaticResource MonoFont}" Foreground="{StaticResource Accent}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
