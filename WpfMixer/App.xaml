<Application x:Class="WpfMixer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:conv="clr-namespace:WpfMixer.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Active theme — swapped at runtime by ThemeService -->
                <ResourceDictionary Source="pack://application:,,,/WpfMixer;component/Themes/Dark.xaml"/>
                <!-- Animation helpers (easing curves + button/tab styles) -->
                <ResourceDictionary Source="pack://application:,,,/WpfMixer;component/Themes/Animations.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- ══ DERIVED BRUSHES (rebuilt by ThemeService on theme switch) ════ -->
            <SolidColorBrush x:Key="BgDeep"          Color="{DynamicResource BgDeepColor}"/>
            <SolidColorBrush x:Key="BgPanel"         Color="{DynamicResource BgPanelColor}"/>
            <SolidColorBrush x:Key="BgStrip"         Color="{DynamicResource BgStripColor}"/>
            <SolidColorBrush x:Key="BgControl"       Color="{DynamicResource BgControlColor}"/>
            <SolidColorBrush x:Key="BorderBrush"     Color="{DynamicResource BorderColor}"/>
            <SolidColorBrush x:Key="Accent"          Color="{DynamicResource AccentColor}"/>
            <SolidColorBrush x:Key="MuteBrush"       Color="{DynamicResource MuteColor}"/>
            <SolidColorBrush x:Key="SoloBrush"       Color="{DynamicResource SoloColor}"/>
            <SolidColorBrush x:Key="SelectBrush"     Color="{DynamicResource SelectColor}"/>
            <SolidColorBrush x:Key="TextPrimary"     Color="{DynamicResource TextPrimaryColor}"/>
            <SolidColorBrush x:Key="TextSecondary"   Color="{DynamicResource TextSecondaryColor}"/>
            <SolidColorBrush x:Key="FaderTrackBrush" Color="{DynamicResource FaderTrackColor}"/>

            <!-- ══ TYPOGRAPHY ════════════════════════════════════════════════════ -->
            <FontFamily x:Key="UIFont">Segoe UI, Arial</FontFamily>
            <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, Courier New</FontFamily>
            <FontFamily x:Key="HeadingFont">Segoe UI Semibold, Segoe UI, Arial</FontFamily>
            <sys:Double x:Key="GlobalFontSize">12</sys:Double>

            <!-- ══ WINDOW ═════════════════════════════════════════════════════════ -->
            <Style TargetType="Window">
                <Setter Property="Background"  Value="{DynamicResource BgDeep}"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="FontFamily"  Value="{StaticResource UIFont}"/>
                <Setter Property="FontSize"    Value="{DynamicResource GlobalFontSize}"/>
            </Style>

            <!-- ══ SCROLLBAR (slim dark) ══════════════════════════════════════════ -->
            <Style TargetType="ScrollBar">
                <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
                <Setter Property="Width" Value="8"/>
            </Style>

            <!-- ══ BUTTON – base ════════════════════════════════════════════════ -->
            <Style x:Key="PtButton" TargetType="Button">
                <Setter Property="Background"       Value="{DynamicResource BgControl}"/>
                <Setter Property="Foreground"       Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush"      Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness"  Value="1"/>
                <Setter Property="Padding"          Value="8,4"/>
                <Setter Property="Cursor"           Value="Hand"/>
                <Setter Property="FontSize"         Value="11"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{DynamicResource RadiusSmall}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource BgHoverColor}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="{DynamicResource BgPressColor}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- MUTE button -->
            <Style x:Key="MuteButton" TargetType="Button" BasedOn="{StaticResource PtButton}">
                <Setter Property="Background"   Value="#FF3A1A1A"/>
                <Setter Property="BorderBrush"  Value="#FF7A1A1A"/>
                <Setter Property="Foreground"   Value="#FFCC4444"/>
                <Setter Property="FontWeight"   Value="Bold"/>
            </Style>
            <Style x:Key="MuteButtonActive" TargetType="Button" BasedOn="{StaticResource PtButton}">
                <Setter Property="Background"   Value="{DynamicResource MuteBrush}"/>
                <Setter Property="BorderBrush"  Value="#FFFF5252"/>
                <Setter Property="Foreground"   Value="White"/>
                <Setter Property="FontWeight"   Value="Bold"/>
            </Style>

            <!-- SOLO button -->
            <Style x:Key="SoloButton" TargetType="Button" BasedOn="{StaticResource PtButton}">
                <Setter Property="Background"   Value="#FF3A2A00"/>
                <Setter Property="BorderBrush"  Value="#FF7A5A00"/>
                <Setter Property="Foreground"   Value="#FFCC8800"/>
                <Setter Property="FontWeight"   Value="Bold"/>
            </Style>
            <Style x:Key="SoloButtonActive" TargetType="Button" BasedOn="{StaticResource PtButton}">
                <Setter Property="Background"   Value="{DynamicResource SoloBrush}"/>
                <Setter Property="Foreground"   Value="Black"/>
                <Setter Property="FontWeight"   Value="Bold"/>
            </Style>

            <!-- ══ VERTICAL FADER SLIDER ══════════════════════════════════════════ -->
            <Style x:Key="VerticalFader" TargetType="Slider">
                <Setter Property="Orientation"  Value="Vertical"/>
                <Setter Property="Minimum"      Value="0"/>
                <Setter Property="Maximum"      Value="1"/>
                <Setter Property="SmallChange"  Value="0.01"/>
                <Setter Property="LargeChange"  Value="0.05"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Track -->
                                <Border Grid.Row="1" Width="4" HorizontalAlignment="Center"
                                        Background="{DynamicResource FaderTrackBrush}"
                                        CornerRadius="2"/>
                                <!-- Unity mark -->
                                <Border Grid.Row="1" Width="10" Height="2"
                                        Background="#FF555555" HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Margin="0,-20,0,0"/>
                                <Track Grid.Row="1" x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                      Background="Transparent" BorderThickness="0" Opacity="0"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb x:Name="thumb">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Border Width="36" Height="14" CornerRadius="2">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#FFD0D0D0" Offset="0"/>
                                                                <GradientStop Color="#FF888888" Offset="0.5"/>
                                                                <GradientStop Color="#FFAAAAAA" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                        <Border Height="2" Width="24"
                                                                Background="#FF333333"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                      Background="Transparent" BorderThickness="0" Opacity="0"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ PAN SLIDER (horizontal, thin) ══════════════════════════════════ -->
            <Style x:Key="PanSlider" TargetType="Slider">
                <Setter Property="Orientation"  Value="Horizontal"/>
                <Setter Property="Minimum"      Value="0"/>
                <Setter Property="Maximum"      Value="1"/>
                <Setter Property="Height"       Value="20"/>
                <Setter Property="Cursor"       Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid>
                                <Border Height="3" VerticalAlignment="Center"
                                        Background="{DynamicResource FaderTrackBrush}" CornerRadius="1"/>
                                <Border Width="2" Height="8" HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Background="#FF555555"/>
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                      Background="Transparent" BorderThickness="0" Opacity="0"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Ellipse Width="12" Height="12">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop Color="#FFE0E0E0" Offset="0"/>
                                                                <GradientStop Color="#FF888888" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                      Background="Transparent" BorderThickness="0" Opacity="0"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══ TEXTBOX ══════════════════════════════════════════════════════ -->
            <Style TargetType="TextBox">
                <Setter Property="Background"  Value="{DynamicResource BgControl}"/>
                <Setter Property="Foreground"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="CaretBrush"  Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Padding"     Value="4,2"/>
            </Style>

            <!-- ══ LABEL / TEXTBLOCK ══════════════════════════════════════════════ -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            </Style>
            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            </Style>

            <!-- ══ SCROLLVIEWER ════════════════════════════════════════════════ -->
            <Style TargetType="ScrollViewer">
                <Setter Property="Background" Value="Transparent"/>
            </Style>

            <!-- ══ SHARED CONVERTER INSTANCES ══════════════════════════════════ -->
            <conv:DoubleToDbStringConverter x:Key="DoubleToDbStr"/>
            <conv:EnumToBoolConverter       x:Key="EnumToBool"/>

        </ResourceDictionary>
    </Application.Resources>
</Application>

