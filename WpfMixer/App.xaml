<Application x:Class="WpfMixer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>

        <!-- ═══ PALETTE ═══════════════════════════════════════════════════════ -->
        <Color x:Key="BgDeepColor">#FF0D0D0D</Color>
        <Color x:Key="BgPanelColor">#FF1A1A1A</Color>
        <Color x:Key="BgStripColor">#FF222222</Color>
        <Color x:Key="BgControlColor">#FF2A2A2A</Color>
        <Color x:Key="BorderColor">#FF3C3C3C</Color>
        <Color x:Key="AccentColor">#FF1DB954</Color>
        <Color x:Key="MuteColor">#FFE53935</Color>
        <Color x:Key="SoloColor">#FFFFA000</Color>
        <Color x:Key="SelectColor">#FF1565C0</Color>
        <Color x:Key="TextPrimaryColor">#FFE0E0E0</Color>
        <Color x:Key="TextSecondaryColor">#FF888888</Color>
        <Color x:Key="FaderTrackColor">#FF333333</Color>
        <Color x:Key="FaderThumbColor">#FFB0B0B0</Color>
        <Color x:Key="MeterGreenColor">#FF00C853</Color>
        <Color x:Key="MeterYellowColor">#FFFFD600</Color>
        <Color x:Key="MeterRedColor">#FFFF1744</Color>

        <SolidColorBrush x:Key="BgDeep"     Color="{StaticResource BgDeepColor}"/>
        <SolidColorBrush x:Key="BgPanel"    Color="{StaticResource BgPanelColor}"/>
        <SolidColorBrush x:Key="BgStrip"    Color="{StaticResource BgStripColor}"/>
        <SolidColorBrush x:Key="BgControl"  Color="{StaticResource BgControlColor}"/>
        <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="Accent"     Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="MuteBrush"  Color="{StaticResource MuteColor}"/>
        <SolidColorBrush x:Key="SoloBrush"  Color="{StaticResource SoloColor}"/>
        <SolidColorBrush x:Key="SelectBrush" Color="{StaticResource SelectColor}"/>
        <SolidColorBrush x:Key="TextPrimary"    Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecondary"  Color="{StaticResource TextSecondaryColor}"/>

        <!-- ═══ FONTS ══════════════════════════════════════════════════════════ -->
        <FontFamily x:Key="MonoFont">Consolas, Courier New</FontFamily>

        <!-- ═══ WINDOW BACKGROUND ══════════════════════════════════════════════ -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource BgDeep}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- ═══ SCROLLBAR (slim dark) ══════════════════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="{StaticResource BgPanel}"/>
            <Setter Property="Width" Value="8"/>
        </Style>

        <!-- ═══ BUTTON – base ══════════════════════════════════════════════════ -->
        <Style x:Key="PtButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource BgControl}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF111111"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MUTE button -->
        <Style x:Key="MuteButton" TargetType="Button" BasedOn="{StaticResource PtButton}">
            <Setter Property="Background" Value="#FF3A1A1A"/>
            <Setter Property="BorderBrush" Value="#FF7A1A1A"/>
            <Setter Property="Foreground" Value="#FFCC4444"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="MuteButtonActive" TargetType="Button" BasedOn="{StaticResource PtButton}">
            <Setter Property="Background" Value="{StaticResource MuteBrush}"/>
            <Setter Property="BorderBrush" Value="#FFFF5252"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- SOLO button -->
        <Style x:Key="SoloButton" TargetType="Button" BasedOn="{StaticResource PtButton}">
            <Setter Property="Background" Value="#FF3A2A00"/>
            <Setter Property="BorderBrush" Value="#FF7A5A00"/>
            <Setter Property="Foreground" Value="#FFCC8800"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="SoloButtonActive" TargetType="Button" BasedOn="{StaticResource PtButton}">
            <Setter Property="Background" Value="{StaticResource SoloBrush}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- ═══ VERTICAL FADER SLIDER ══════════════════════════════════════════ -->
        <Style x:Key="VerticalFader" TargetType="Slider">
            <Setter Property="Orientation" Value="Vertical"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="SmallChange" Value="0.01"/>
            <Setter Property="LargeChange" Value="0.05"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Track -->
                            <Border Grid.Row="1" Width="4" HorizontalAlignment="Center"
                                    Background="{StaticResource FaderTrackColor}"
                                    CornerRadius="2"/>

                            <!-- Unity mark at 75% (0.75) -->
                            <Border Grid.Row="1" Width="10" Height="2"
                                    Background="#FF555555" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Margin="0,-20,0,0"/>

                            <Track Grid.Row="1" x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Background="Transparent" BorderThickness="0"
                                                  Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="thumb">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="36" Height="14"
                                                        CornerRadius="2">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#FFD0D0D0" Offset="0"/>
                                                            <GradientStop Color="#FF888888" Offset="0.5"/>
                                                            <GradientStop Color="#FFAAAAAA" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <!-- Center line on fader cap -->
                                                    <Border Height="2" Width="24"
                                                            Background="#FF333333"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Background="Transparent" BorderThickness="0"
                                                  Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PAN SLIDER (horizontal, thin) ═══════════════════════════════════ -->
        <Style x:Key="PanSlider" TargetType="Slider">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="1"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Border Height="3" VerticalAlignment="Center"
                                    Background="{StaticResource FaderTrackColor}" CornerRadius="1"/>
                            <Border Width="2" Height="8" HorizontalAlignment="Center"
                                    VerticalAlignment="Center" Background="#FF555555"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge"
                                                  Background="Transparent" BorderThickness="0" Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="12" Height="12">
                                                    <Ellipse.Fill>
                                                        <RadialGradientBrush>
                                                            <GradientStop Color="#FFE0E0E0" Offset="0"/>
                                                            <GradientStop Color="#FF888888" Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge"
                                                  Background="Transparent" BorderThickness="0" Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBOX ════════════════════════════════════════════════════════ -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource BgControl}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>

        <!-- ═══ LABEL / TEXTBLOCK ══════════════════════════════════════════════ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- ═══ SCROLLVIEWER ═══════════════════════════════════════════════════ -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

    </Application.Resources>
</Application>

