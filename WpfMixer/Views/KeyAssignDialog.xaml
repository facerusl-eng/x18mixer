<Window x:Class="WpfMixer.Views.KeyAssignDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Key" Width="360" Height="260"
        Background="#1a1a2e" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20">
        <TextBlock Text="Press any key to assign, or click Clear." 
                   Foreground="#ccc" TextWrapping="Wrap" Margin="0,0,0,12"/>

        <!-- Live key capture area -->
        <Border Background="#0f3460" CornerRadius="8" Height="60"
                BorderBrush="#e94560" BorderThickness="2"
                Focusable="True" x:Name="KeyCaptureArea"
                PreviewKeyDown="KeyCaptureArea_PreviewKeyDown">
            <TextBlock x:Name="KeyDisplay"
                       Text="[press a key]" Foreground="#e94560"
                       FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <CheckBox x:Name="MomentaryCheck" Content="Momentary mode (hold = active)"
                  Foreground="#ccc" Margin="0,14,0,0" IsChecked="False"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Clear" Width="70" Margin="0,0,8,0"
                    Background="#333" Foreground="White" BorderThickness="0"
                    Click="Clear_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="OK" Width="70" Margin="0,0,8,0"
                    Background="#e94560" Foreground="White" BorderThickness="0"
                    Click="OK_Click" IsDefault="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Width="70"
                    Background="#444" Foreground="White" BorderThickness="0"
                    Click="Cancel_Click" IsCancel="True">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
