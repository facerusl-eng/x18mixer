<UserControl x:Class="WpfMixer.Views.PluginsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDeep}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
            <DockPanel>
                <Button DockPanel.Dock="Bottom" Content="Refresh" Command="{Binding RefreshCommand}" Style="{StaticResource PtButton}" Margin="0,8,0,0"/>
                <ListBox ItemsSource="{Binding Plugins}" SelectedItem="{Binding SelectedPlugin}" DisplayMemberPath="Name"/>
            </DockPanel>
        </Border>

        <Border Grid.Column="2" Background="{DynamicResource BgStrip}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
            <ContentPresenter Content="{Binding SelectedPanel}"/>
        </Border>
    </Grid>
</UserControl>
