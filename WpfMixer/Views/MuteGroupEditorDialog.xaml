<Window x:Class="WpfMixer.Views.MuteGroupEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Mute Group" Width="380" Height="420"
        Background="#1a1a2e" WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16">
        <TextBlock Text="Group name:" Foreground="#ccc" Margin="0,0,0,4"/>
        <TextBox x:Name="NameBox" Background="#16213e" Foreground="White"
                 BorderBrush="#444" Padding="6,4" Margin="0,0,0,14"/>

        <TextBlock Text="Channels in this group:" Foreground="#ccc" Margin="0,0,0,6"/>
        <Border Background="#16213e" CornerRadius="6" Padding="6" Height="200">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="ChannelList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Channel.Name}"
                                      IsChecked="{Binding IsInGroup}"
                                      Foreground="White" Margin="0,3"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="Save" Width="70" Background="#e94560"
                    Foreground="White" BorderThickness="0"
                    Click="Save_Click" IsDefault="True" Margin="0,0,8,0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
            <Button Content="Cancel" Width="70" Background="#444"
                    Foreground="White" BorderThickness="0"
                    IsCancel="True" Click="Cancel_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="8,4">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </StackPanel>
</Window>
