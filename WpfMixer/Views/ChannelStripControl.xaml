<UserControl x:Class="WpfMixer.Views.ChannelStripControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WpfMixer.Converters"
             xmlns:views="clr-namespace:WpfMixer.Views"
             Width="70">

    <UserControl.Resources>
        <conv:BoolToMuteColorConverter  x:Key="MuteColor"/>
        <conv:BoolToMuteTextConverter   x:Key="MuteText"/>
        <conv:BoolToHighlightConverter  x:Key="Highlight"/>
        <conv:BoolToSoloColorConverter  x:Key="SoloColor"/>
        <conv:BoolToSelectBorderConverter x:Key="SelectBorder"/>
        <conv:DoubleToDbStringConverter x:Key="DbLabel"/>
    </UserControl.Resources>

    <!-- Outer: selection highlight border -->
    <Border x:Name="StripOuter"
            BorderThickness="1"
            BorderBrush="{Binding IsSelected, Converter={StaticResource SelectBorder}}">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF1C1530" Offset="0"/>
                <GradientStop Color="#FF100A1D" Offset="0.45"/>
                <GradientStop Color="#FF05040B" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="#88A259FF" ShadowDepth="0" BlurRadius="12" Opacity="0.45"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="18"/>   <!-- Row 0: Gain / input dB -->
                <RowDefinition Height="14"/>   <!-- Row 1: 48V / phase icons -->
                <RowDefinition Height="22"/>   <!-- Row 2: Gate mini-display -->
                <RowDefinition Height="28"/>   <!-- Row 3: EQ mini-display -->
                <RowDefinition Height="22"/>   <!-- Row 4: Comp mini-display -->
                <RowDefinition Height="14"/>   <!-- Row 5: Sends indicator -->
                <RowDefinition Height="26"/>   <!-- Row 6: Color + Name -->
                <RowDefinition Height="22"/>   <!-- Row 7: Solo button -->
                <RowDefinition Height="20"/>   <!-- Row 8: dB readout -->
                <RowDefinition Height="14"/>   <!-- Row 9: Pan slider -->
                <RowDefinition Height="*"/>    <!-- Row 10: Fader + Meter -->
                <RowDefinition Height="28"/>   <!-- Row 11: Mute button -->
            </Grid.RowDefinitions>

            <!-- ── Row 0: Gain / Input level ── -->
            <Border Grid.Row="0" Background="#FF0F0F0F"
                    BorderBrush="#FF1A1A1A" BorderThickness="0,0,0,1">
                <TextBlock Text="+0.0"
                           FontFamily="{StaticResource MonoFont}" FontSize="10"
                           Foreground="#FFAAAAAA"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- ── Row 1: 48V + phase indicators ── -->
            <Grid Grid.Row="1" Background="#FF0D0D0D">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#FF1C1C1C" CornerRadius="2" Padding="3,1" Margin="1,0">
                        <TextBlock Text="48" FontSize="8" FontFamily="{StaticResource MonoFont}"
                                   Foreground="#FF444444"/>
                    </Border>
                    <Border Background="#FF1C1C1C" CornerRadius="2" Padding="3,1" Margin="1,0">
                        <TextBlock Text="Ø" FontSize="8" FontFamily="{StaticResource MonoFont}"
                                   Foreground="#FF444444"/>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ── Row 2: Gate mini-display ── -->
            <Border Grid.Row="2" BorderBrush="#FF2A4A2A" BorderThickness="0,1,0,1" Margin="2,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF030E06" Offset="0"/>
                        <GradientStop Color="#FF0A1A0E" Offset="0.5"/>
                        <GradientStop Color="#FF030E06" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Canvas x:Name="GateCanvas" ClipToBounds="True">
                        <!-- Painted in code-behind on SizeChanged; static placeholder line -->
                        <Line X1="0" Y1="11" X2="25" Y2="11" Stroke="#FF1E4D1E" StrokeThickness="1"/>
                        <Line X1="25" Y1="11" X2="30" Y2="2" Stroke="#FF2ECC40" StrokeThickness="1.5"/>
                        <Line X1="30" Y1="2" X2="35" Y2="11" Stroke="#FF2ECC40" StrokeThickness="1.5"/>
                        <Line X1="35" Y1="11" X2="100" Y2="11" Stroke="#FF1E4D1E" StrokeThickness="1"/>
                    </Canvas>
                    <!-- Inset screen shadow overlay -->
                    <Rectangle IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#99000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="0.3"/>
                                <GradientStop Color="#00000000" Offset="0.7"/>
                                <GradientStop Color="#99000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
            </Border>

            <!-- ── Row 3: EQ mini-display ── -->
            <Border Grid.Row="3" BorderBrush="#FF1A1A3A" BorderThickness="0,0,0,1" Margin="2,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF03030E" Offset="0"/>
                        <GradientStop Color="#FF0A0A1C" Offset="0.5"/>
                        <GradientStop Color="#FF03030E" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Canvas x:Name="EqCanvas" ClipToBounds="True">
                        <!-- Static EQ curve placeholder -->
                        <Polyline Points="0,14 8,14 14,10 22,8 30,12 42,9 54,13 66,14"
                                  Stroke="#FF3A5FBF" StrokeThickness="1.5" Fill="Transparent"/>
                    </Canvas>
                    <!-- Inset screen shadow overlay -->
                    <Rectangle IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#99000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="0.3"/>
                                <GradientStop Color="#00000000" Offset="0.7"/>
                                <GradientStop Color="#99000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
            </Border>

            <!-- ── Row 4: Comp mini-display ── -->
            <Border Grid.Row="4" BorderBrush="#FF3A2A0A" BorderThickness="0,0,0,1" Margin="2,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF0E0803" Offset="0"/>
                        <GradientStop Color="#FF1A100A" Offset="0.5"/>
                        <GradientStop Color="#FF0E0803" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Canvas x:Name="CompCanvas" ClipToBounds="True">
                        <!-- Static comp transfer curve placeholder -->
                        <Polyline Points="0,20 12,12 24,7 40,5 66,4"
                                  Stroke="#FFCC8800" StrokeThickness="1.5" Fill="Transparent"/>
                    </Canvas>
                    <!-- Inset screen shadow overlay -->
                    <Rectangle IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#99000000" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="0.3"/>
                                <GradientStop Color="#00000000" Offset="0.7"/>
                                <GradientStop Color="#99000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
            </Border>

            <!-- ── Row 5: Sends level indicator ── -->
            <Border Grid.Row="5" Background="#FF0D0D0D"
                    BorderBrush="#FF1A1A1A" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Rectangle Width="8" Height="8" Fill="#FF225522" Margin="1,0" RadiusX="1" RadiusY="1"/>
                    <Rectangle Width="8" Height="8" Fill="#FF225522" Margin="1,0" RadiusX="1" RadiusY="1"/>
                    <Rectangle Width="8" Height="8" Fill="#FF225522" Margin="1,0" RadiusX="1" RadiusY="1"/>
                    <Rectangle Width="8" Height="8" Fill="#FF225522" Margin="1,0" RadiusX="1" RadiusY="1"/>
                </StackPanel>
            </Border>

            <!-- ── Row 6: Channel color + Name ── -->
            <Border Grid.Row="6"
                    Background="{Binding ColorHex, Converter={x:Static conv:HexToBrushConverter.Instance}}">
                <Grid>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             Foreground="Black"
                             BorderThickness="0" FontSize="10" FontWeight="Bold"
                             TextAlignment="Center" VerticalAlignment="Center"
                             Padding="2,0" Margin="0,0,18,0"/>
                    <!-- Key badge -->
                    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                            Background="#44000000" CornerRadius="2" Padding="2,1"
                            Margin="0,1,2,0" Cursor="Hand"
                            MouseLeftButtonUp="KeyBadge_Click">
                        <TextBlock FontSize="8" Foreground="#CCFFFFFF"
                                   FontFamily="{StaticResource MonoFont}"
                                   Text="{Binding AssignedKey, FallbackValue='—'}"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Row 7: Solo button ── -->
            <Button Grid.Row="7" Content="Solo" Margin="3,2"
                    Background="{Binding IsSolo, Converter={StaticResource SoloColor}}"
                    Foreground="#FFFFA000"
                    Style="{StaticResource SoloButton}"
                    Click="Solo_Click" FontSize="10" FontWeight="Bold" Padding="0"/>

            <!-- ── Row 8: dB readout ── -->
            <Border Grid.Row="8" Background="#FF0D0D0D"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,1">
                <TextBlock Text="{Binding FaderLevel, Converter={StaticResource DbLabel}}"
                           FontFamily="{StaticResource MonoFont}" FontSize="11"
                           Foreground="#FF00E676"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- ── Row 9: Pan slider ── -->
            <Grid Grid.Row="9" Background="#FF141414" Margin="4,0">
                <Slider Style="{StaticResource PanSlider}"
                        Value="{Binding Pan}"
                        VerticalAlignment="Center"/>
                <TextBlock Text="·" FontSize="9" Foreground="#FF333333"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>

            <!-- ── Row 10: Fader + LED meter ── -->
            <Grid Grid.Row="10" Margin="3,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                </Grid.ColumnDefinitions>

                <Slider Grid.Column="0"
                        Style="{StaticResource VerticalFader}"
                        Value="{Binding FaderLevel}"
                        HorizontalAlignment="Center"/>

                <views:LedMeterControl Grid.Column="1"
                                       Level="{Binding MeterLevel}"
                                       VerticalAlignment="Stretch"/>
            </Grid>

            <!-- ── Row 11: MUTE button ── -->
            <Button Grid.Row="11" Content="Mute" Margin="2,2"
                    Style="{StaticResource MuteButton}"
                    Background="{Binding IsMuted, Converter={StaticResource MuteColor}}"
                    Foreground="White"
                    Click="Mute_Click" FontSize="10" FontWeight="Bold" Padding="0"/>

            <!-- Key highlight flash overlay -->
            <Border Grid.RowSpan="12"
                    BorderThickness="2"
                    BorderBrush="{Binding IsKeyHighlighted, Converter={StaticResource Highlight}}"
                    IsHitTestVisible="False"/>
        </Grid>
    </Border>
</UserControl>

