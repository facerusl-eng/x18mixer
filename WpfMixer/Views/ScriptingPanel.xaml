<UserControl x:Class="WpfMixer.Views.ScriptingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDeep}">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Column="0" Grid.RowSpan="2" Background="{DynamicResource BgPanel}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8">
            <StackPanel>
                <TextBlock Text="SCRIPT LIBRARY" FontFamily="{StaticResource MonoFont}" FontWeight="Bold" Margin="0,0,0,8"/>
                <ListBox ItemsSource="{Binding ScriptLibrary}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Content="Load Script" Command="{Binding DataContext.LoadFromLibraryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource PtButton}" Margin="0,0,0,6"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <TextBox Grid.Column="2" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Text="{Binding ScriptText, UpdateSourceTrigger=PropertyChanged}" FontFamily="{StaticResource MonoFont}"/>

        <StackPanel Grid.Column="2" Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
            <Button Content="Run" Style="{StaticResource PtButton}" Command="{Binding RunCommand}" Margin="0,0,6,0"/>
            <Button Content="Stop" Style="{StaticResource PtButton}" Command="{Binding StopCommand}" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding OutputText}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
        </StackPanel>
    </Grid>
</UserControl>
