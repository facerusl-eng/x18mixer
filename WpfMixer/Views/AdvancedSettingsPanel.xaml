<UserControl x:Class="WpfMixer.Views.AdvancedSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgDeep}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="14" Width="520">
            <TextBlock Text="ADVANCED SETTINGS" FontFamily="{StaticResource HeadingFont}" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>

            <TextBlock Text="OSC Rate Limit"/>
            <TextBox Text="{Binding OscRateLimitPerSecond, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>

            <TextBlock Text="Meter Update Rate (Hz)"/>
            <TextBox Text="{Binding MeterUpdateRateHz, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>

            <TextBlock Text="Automation Precision (ms)"/>
            <TextBox Text="{Binding AutomationPrecisionMs, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>

            <TextBlock Text="Local API Port"/>
            <TextBox Text="{Binding LocalApiPort, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>

            <TextBlock Text="API Token"/>
            <TextBox Text="{Binding ApiToken, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,8"/>

            <CheckBox Content="Allow External Plugins" IsChecked="{Binding AllowExternalPlugins}" Margin="0,4,0,4"/>
            <CheckBox Content="Allow Plugin Automation Hooks" IsChecked="{Binding AllowPluginAutomationHooks}" Margin="0,0,0,4"/>
            <CheckBox Content="Enable Script Sandboxing" IsChecked="{Binding ScriptSandboxEnabled}" Margin="0,0,0,4"/>
            <CheckBox Content="Use Isolated Script Host Process" IsChecked="{Binding UseIsolatedScriptHost}" Margin="0,0,0,12"/>

            <Button Content="Save Advanced Settings" Style="{StaticResource PtButton}" Command="{Binding SaveCommand}" Width="180"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
