<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         DARK THEME  (Pro Tools / Studio console aesthetic)
         This is the default theme. All keys match the contracts used in Brushes.xaml
         ═══════════════════════════════════════════════════════════════════════ -->

    <!-- ── Background hierarchy ─────────────────────────────────────────── -->
    <Color x:Key="BgDeepColor">    #FF0D0D0D</Color>
    <Color x:Key="BgPanelColor">   #FF1A1A1A</Color>
    <Color x:Key="BgStripColor">   #FF222222</Color>
    <Color x:Key="BgControlColor"> #FF2A2A2A</Color>
    <Color x:Key="BgHoverColor">   #FF3A3A3A</Color>
    <Color x:Key="BgPressColor">   #FF111111</Color>

    <!-- ── Borders ───────────────────────────────────────────────────────── -->
    <Color x:Key="BorderColor">    #FF3C3C3C</Color>
    <Color x:Key="BorderFocusColor">#FF666666</Color>

    <!-- ── Accent / brand ────────────────────────────────────────────────── -->
    <Color x:Key="AccentColor">    #FF1DB954</Color>   <!-- Spotify green -->
    <Color x:Key="AccentDimColor"> #FF0E5C2A</Color>
    <Color x:Key="AccentGlowColor">#3D1DB954</Color>

    <!-- ── Status ────────────────────────────────────────────────────────── -->
    <Color x:Key="MuteColor">      #FFE53935</Color>
    <Color x:Key="SoloColor">      #FFFFA000</Color>
    <Color x:Key="SelectColor">    #FF1565C0</Color>
    <Color x:Key="ClipColor">      #FFFF1744</Color>
    <Color x:Key="WarningColor">   #FFFF8F00</Color>

    <!-- ── Text ──────────────────────────────────────────────────────────── -->
    <Color x:Key="TextPrimaryColor">  #FFE0E0E0</Color>
    <Color x:Key="TextSecondaryColor">#FF888888</Color>
    <Color x:Key="TextDimColor">      #FF4A4A4A</Color>
    <Color x:Key="TextOnAccentColor"> #FF000000</Color>

    <!-- ── Fader / meter ─────────────────────────────────────────────────── -->
    <Color x:Key="FaderTrackColor">   #FF333333</Color>
    <Color x:Key="FaderThumbColor">   #FFB0B0B0</Color>
    <Color x:Key="MeterGreenColor">   #FF00C853</Color>
    <Color x:Key="MeterYellowColor">  #FFFFD600</Color>
    <Color x:Key="MeterRedColor">     #FFFF1744</Color>
    <Color x:Key="MeterOffGreenColor">#FF0A2A0A</Color>
    <Color x:Key="MeterOffYellColor"> #FF3A3000</Color>
    <Color x:Key="MeterOffRedColor">  #FF3A0A0A</Color>
    <Color x:Key="PeakHoldColor">     #FFFFFFFF</Color>
    <Color x:Key="ClipLedColor">      #FFFF1744</Color>

    <!-- ── Corner radii ──────────────────────────────────────────────────── -->
    <CornerRadius x:Key="RadiusSmall">3</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">6</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">10</CornerRadius>
    <CornerRadius x:Key="RadiusStrip">4,4,0,0</CornerRadius>

    <!-- ── Shadows (DropShadowEffect params used in code) ────────────────── -->
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                x:Key="ShadowBlurSmall">4</sys:Double>
    <sys:Double xmlns:sys="clr-namespace:System;assembly=mscorlib"
                x:Key="ShadowBlurMedium">12</sys:Double>
    <Color x:Key="ShadowColor">#88000000</Color>

</ResourceDictionary>
